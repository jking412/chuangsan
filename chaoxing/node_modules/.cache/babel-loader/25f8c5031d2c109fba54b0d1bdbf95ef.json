Val, oldVal) {\n      this.drawLine()\n      console.log(11);\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('map6'))\n      // 绘制图表\n      myChart.setOption({\n        title: {\n          text: this.value * 100 + '%',\n          textStyle: {\n\n            fontWeight: 'normal',\n            color: '#fff',\n            fontWeight: 'bold',\n          },\n          x: 'center',\n          y: '35%'\n        },\n        graphic: [{\n          type: 'group',\n          left: 'center',\n          top: '50%',\n          children: [{\n            type: 'text',\n            z: 100,\n            left: '6',\n            top: 'middle',\n            style: {\n              fill: '#fff',\n              text: '及格率',\n              font: '20px'\n            }\n          }]\n        }],\n\n        series: [{\n          type: 'liquidFill',\n          data: [this.value, this.value, this.value, this.value],\n          radius: '70%', // 水球半径，可以是数值或百分比\n          amplitude: 10, // 振幅，影响水波的高度\n          color: [{\n            type: 'linear',\n            x: 0,\n            y: 1,\n            x2: 0,\n            y2: 0,\n            colorStops: [{\n              offset: 1,\n              color: ['#43e97b'], // 0% 处的颜色\n            }, {\n              offset: 0,\n              color: ['#38f9d7'], // 100% 处的颜色\n            }],\n            global: false // 缺省为 false\n          }],\n          outline: {\n            show: false\n          }, // 是否显示边框\n          backgroundStyle: {\n            color: '#e5e5e5'\n          }, // 背景颜色\n          label: {\n            show: false,\n          }\n        }]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n"],"mappings":";;;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,KAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,KAAA;IACAC,KAAA,WAA