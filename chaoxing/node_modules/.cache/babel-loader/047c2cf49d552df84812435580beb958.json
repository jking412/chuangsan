rawLine()\n  },\n  methods: {\n    drawLine() {\n      let that = this\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('main1'))\n      // 绘制图表\n      myChart.setOption(\n        {\n          title: {\n            text: '学习进步情况',\n            left: 'center'\n          },\n          tooltip: {\n            trigger: 'axis',\n            axisPointer: {\n              type: 'cross',\n              crossStyle: {\n                color: '#999'\n              }\n            }\n          },\n          legend: {\n            data: ['进步得分', '进步率'],\n            left: 'center',\n            top: 'bottom',\n          },\n\n          xAxis: [\n            {\n              type: 'category',\n              data: ['第一周', '第二周', '第三周', '第四周', '第五周', '第六周', '第七周', '第八周'],\n              axisPointer: {\n                type: 'shadow'\n              }\n            }\n          ],\n          yAxis: [\n            {\n              type: 'value',\n              name: '进步得分',\n              min: -100,\n              max: 100,\n              interval: 20,\n              axisLabel: {\n                formatter: '{value} '\n              }\n            },\n            {\n              type: 'value',\n              name: '得分率',\n              min: -100,\n              max: 100,\n              interval: 20,\n              axisLabel: {\n                formatter: '{value} %'\n              }\n            }\n          ],\n          series: [\n            {\n              name: '进步得分',\n              type: 'bar',\n              tooltip: {\n                valueFormatter: function (value) {\n                  return value;\n                }\n              },\n              data: [\n                10, 20, 30, 50, 60, 40, 20, 20\n              ],\n              barWidth: 30,\n              itemStyle: {\n                color: '#00b6ff'\n              },\n            },\n            {\n              name: '进步率',\n              type: 'line',\n              yAxisIndex: 1,\n              tooltip: {\n                valueFormatter: function (value) {\n                  return value + ' %';\n                }\n              },\n              data: [0, 100, 50, 66, 17, -33, -50, 0],\n              itemStyle: {\n                color: '#3fea8f'\n              },\n            },\n\n          ]\n        }\n      )\n      myChart.on('click', function (params) {\n\n        that.$emit('callback', [true, params.name])\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n\n    }\n  }\n}\n\n</script>\n\n\n\n"],"mappings":";;;;;;;;;;AASA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,mBAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA,IAAAE,IAAA;MACA;MACA,IAAAC,OAAA,GAAAR,OAAA,CAAAS,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA,CACA;QACAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;UACAC,WAAA;YACAC,IAAA;YACAC,UAAA;cACAC,KAAA;YACA;UACA;QACA;QACAC,MAAA;UACApB,IAAA;UACAa,IAAA;UACAQ,GAAA;QACA;QAEAC,KAAA,GACA;UACAL,IAAA;UACAjB,IAAA;UACAgB,WAAA;YACAC,IAAA;UACA;QACA,EACA;QACAM,KAAA,GACA;UACAN,IAAA;UACAlB,IAAA;UACAyB,GAAA;UACAC,GAAA;UACAC,QAAA;UACAC,SAAA;YACAC,SAAA;UACA;QACA,GACA;UACAX,IAAA;UACAlB,IAAA;UACAyB,GAAA;UACAC,GAAA;UACAC,QAAA;UACAC,SAAA;YACAC,SAAA;UACA;QACA,EACA;QACAC,MAAA,GACA;UACA9B,IAAA;UACAkB,IAAA;UACAH,OAAA;YACAgB,cAAA,WAAAA,eAAAC,KAAA;cACA,OAAAA,KAAA;YACA;UACA;UACA/B,IAAA,GACA,+BACA;UACAgC,QAAA;UACAC,SAAA;YACAd,KAAA;UACA;QACA,GACA;UACApB,IAAA;UACAkB,IAAA;UACAiB,UAAA;UACApB,OAAA;YACAgB,cAAA,WAAAA,eAAAC,KAAA;cACA,OAAAA,KAAA;YACA;UACA;UACA/B,IAAA;UACAiC,SAAA;YACAd,KAAA;UACA;QACA;MAGA,EACA;MACAb,OAAA,CAAA6B,EAAA,oBAAAC,MAAA;QAEA/B,IAAA,CAAAgC,KAAA,oBAAAD,MAAA,CAAArC,IAAA;MACA;MACAuC,MAAA,CAAAC,gBAAA;QACAjC,OAAA,CAAAkC,MAAA;MACA;IAEA;EACA;AACA"}]}