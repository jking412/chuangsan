  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('exa3'))\n      // 绘制图表\n      myChart.setOption({\n\n        title: {\n          text: '个人学习风格雷达图',\n          left: 'center'\n        },\n        tooltip: {\n          confine: true,\n          trigger: 'item',\n          formatter: function (params, ticket, callback) {\n            var showHtm = \"\";\n            for (var i = 0; i < params.value.length; i++) {\n              //名称\n              var name = params.data.name[i];\n              //值\n              var value = params.value[i];\n              showHtm += name + ' 得分：' + value + '<br>'\n            }\n            return showHtm;\n          }\n        },\n        legend: {\n          left: 'center',\n          top: 'bottom',\n          data: ['学习风格倾向']\n        },\n        radar: {\n          // shape: 'circle',\n          indicator: [\n            { name: '视觉型', max: 10 },\n            { name: '听觉型', max: 10 },\n            { name: '互动型', max: 10 },\n            { name: '读写型', max: 10 },\n            { name: '社交型', max: 10 },\n\n          ],\n          AxisName: { // (圆外的标签)雷达图每个指示器名称的配置项。\n            fontSize: 13,\n            color: 'black'\n          },\n\n        },\n        series: [\n          {\n            name: '学习风格倾向',\n            type: 'radar',\n            label: {  //显示value中具体的数值\n              show: true,\n              extStyle: {  //更改数值样式\n                color: 'blue'\n              }\n            },\n            data: [\n              {\n                value: this.data[0],\n                name: this.data[1],\n                areaStyle: { color: \"#a9d4f6\" }, //阴影背景颜色\n                lineStyle: {\n                  color: \"#4890ff\",\n                  // 阴影折线宽度\n                  width: 1\n                },\n\n              }\n            ]\n          }\n        ]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"],"mappings":";;;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAA,IAAA,GACA,2BACA;IAEA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAN,OAAA,CAAAO,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA;QAEAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;UACAC,OAAA;UACAC,SAAA,WAAAA,UAAAC,MAAA,EAAAC,MAAA,EAAAC,QAAA;YACA,IAAAC,OAAA;YACA,SAAAC,CAAA,MAAAA,CAAA,GAAAJ,MAAA,CAAAK,KAAA,CAAAC,MAAA,EAAAF,CAAA;cACA;cACA,IAAArB,IAAA,GAAAiB,MAAA,CAAAhB,IAAA,CAAAD,IAAA,CAAAqB,CAAA;cACA;cACA,IAAAC,KAAA,GAAAL,MAAA,CAAAK,KAAA,CAAAD,CAAA;cACAD,OAAA,IAAApB,IAAA,YAAAsB,KAAA;YACA;YACA,OAAAF,OAAA;UACA;QACA;QACAI,MAAA;UACAZ,IAAA;UACAa,GAAA;UACAxB,IAAA;QACA;QACAyB,KAAA;UACA;UACAC,SAAA,GACA;YAAA3B,IAAA;YAAA4B,GAAA;UAAA,GACA;YAAA5B,IAAA;YAAA4B,GAAA;UAAA,GACA;YAAA5B,IAAA;YAAA4B,GAAA;UAAA,GACA;YAAA5B,IAAA;YAAA4B,GAAA;UAAA,GACA;YAAA5B,IAAA;YAAA4B,GAAA;UAAA,EAEA;UACAC,QAAA;YAAA;YACAC,QAAA;YACAC,KAAA;UACA;QAEA;QACAC,MAAA,GACA;UACAhC,IAAA;UACAiC,IAAA;UACAC,KAAA;YAAA;YACAC,IAAA;YACAC,QAAA;cAAA;cACAL,KAAA;YACA;UACA;UACA9B,IAAA,GACA;YACAqB,KAAA,OAAArB,IAAA;YACAD,IAAA,OAAAC,IAAA;YACAoC,SAAA;cAAAN,KAAA;YAAA;YAAA;YACAO,SAAA;cACAP,KAAA;cACA;cACAQ,KAAA;YACA;UAEA;QAEA;MAEA;MACAC,MAAA,CAAAC,gBAAA;QACApC,OAAA,CAAAqC,MAAA;MACA;IACA;EACA;AACA"}]}