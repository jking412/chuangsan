r\n  name: 'radar',\r\n  data() {\r\n    return {\r\n      msg: 'Welcome to Your Vue.js App'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.drawLine()\r\n  },\r\n  methods: {\r\n    drawLine() {\r\n      // 基于准备好的dom，初始化echarts实例\r\n      var myChart = echarts.init(document.getElementById('exa3'))\r\n      // 绘制图表\r\n      myChart.setOption({\r\n\r\n        title: {\r\n          text: '课业完成情况雷达图',\r\n          left: 'center'\r\n        },\r\n        tooltip: {\r\n          confine: true,\r\n          trigger: 'item',\r\n          formatter: function (params, ticket, callback) {\r\n            console.log(params);\r\n            var showHtm = \"\";\r\n            for (var i = 0; i < params.value.length; i++) {\r\n              //名称\r\n              var name = params.data.name[i];\r\n              //值\r\n              var value = params.value[i];\r\n\r\n              showHtm += name + ' 得分：' + value + '<br>'\r\n            }\r\n\r\n            return showHtm;\r\n          }\r\n\r\n        },\r\n\r\n        legend: {\r\n          left: 'center',\r\n          top: 'bottom',\r\n          data: ['学习风格倾向']\r\n        },\r\n        radar: {\r\n          // shape: 'circle',\r\n          indicator: [\r\n            { name: '视觉型', max: 10 },\r\n            { name: '听觉型', max: 10 },\r\n            { name: '互动型', max: 10 },\r\n            { name: '读写型', max: 10 },\r\n            { name: '社交型', max: 10 },\r\n\r\n          ],\r\n          name: { // (圆外的标签)雷达图每个指示器名称的配置项。\r\n\r\n            textStyle: {\r\n              fontSize: 13,\r\n              color: 'black'\r\n            }\r\n          },\r\n\r\n        },\r\n        series: [\r\n          {\r\n            name: '学习风格倾向',\r\n            type: 'radar',\r\n            label: {  //显示value中具体的数值\r\n              normal: {\r\n                show: true,\r\n                extStyle: {  //更改数值样式\r\n                  color: 'blue'\r\n                }\r\n              },\r\n            },\r\n            data: [\r\n              {\r\n                value: [7.8, 8.2, 5.6, 9.2, 6.3],\r\n                name: ['视觉型', '听觉型', '互动型', '读写型', ' 社交型'],\r\n                areaStyle: { color: \"#a9d4f6\" }, //阴影背景颜色\r\n                lineStyle: {\r\n                  color: \"#4890ff\",\r\n                  // 阴影折线宽度\r\n                  width: 1\r\n                },\r\n\r\n              }\r\n            ]\r\n          }\r\n        ]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n\r\n\r\n"],"mappings":";;;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAP,OAAA,CAAAQ,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA;QAEAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;UACAC,OAAA;UACAC,SAAA,WAAAA,UAAAC,MAAA,EAAAC,MAAA,EAAAC,QAAA;YACAC,OAAA,CAAAC,GAAA,CAAAJ,MAAA;YACA,IAAAK,OAAA;YACA,SAAAC,CAAA,MAAAA,CAAA,GAAAN,MAAA,CAAAO,KAAA,CAAAC,MAAA,EAAAF,CAAA;cACA;cACA,IAAAxB,IAAA,GAAAkB,MAAA,CAAAjB,IAAA,CAAAD,IAAA,CAAAwB,CAAA;cACA;cACA,IAAAC,KAAA,GAAAP,MAAA,CAAAO,KAAA,CAAAD,CAAA;cAEAD,OAAA,IAAAvB,IAAA,YAAAyB,KAAA;YACA;YAEA,OAAAF,OAAA;UACA;QAEA;QAEAI,MAAA;UACAd,IAAA;UACAe,GAAA;UACA3B,IAAA;QACA;QACA4B,KAAA;UACA;UACAC,SAAA,GACA;YAAA9B,IAAA;YAAA+B,GAAA;UAAA,GACA;YAAA/B,IAAA;YAAA+B,GAAA;UAAA,GACA;YAAA/B,IAAA;YAAA+B,GAAA;UAAA,GACA;YAAA/B,IAAA;YAAA+B,GAAA;UAAA,GACA;YAAA/B,IAAA;YAAA+B,GAAA;UAAA,EAEA;UACA/B,IAAA;YAAA;;YAEAgC,SAAA;cACAC,QAAA;cACAC,KAAA;YACA;UACA;QAEA;QACAC,MAAA,GACA;UACAnC,IAAA;UACAoC,IAAA;UACAC,KAAA;YAAA;YACAC,MAAA;cACAC,IAAA;cACAC,QAAA;gBAAA;gBACAN,KAAA;cACA;YACA;UACA;UACAjC,IAAA,GACA;YACAwB,KAAA;YACAzB,IAAA;YACAyC,SAAA;cAAAP,KAAA;YAAA;YAAA;YACAQ,SAAA;cACAR,KAAA;cACA;cACAS,KAAA;YACA;UAEA;QAEA;MAEA;MACAC,MAAA,CAAAC,gBAAA;QACAvC,OAAA,CAAAwC,MAAA;MACA;IACA;EACA;AACA"}]}