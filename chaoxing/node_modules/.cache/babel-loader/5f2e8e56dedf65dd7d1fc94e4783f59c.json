\r\n<script>\r\nimport * as echarts from 'echarts'\r\nexport default {\r\n  name: 'Aosa',\r\n  data() {\r\n    return {\r\n      msg: 'Welcome to Your Vue.js App'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.drawLine()\r\n  },\r\n  methods: {\r\n    drawLine() {\r\n      // 基于准备好的dom，初始化echarts实例\r\n      var myChart = echarts.init(document.getElementById('main1'))\r\n      // 绘制图表\r\n      myChart.setOption(\r\n        {\r\n          title: {\r\n            text: '学习进步情况',\r\n            left: 'center'\r\n          },\r\n          tooltip: {\r\n            trigger: 'axis',\r\n            axisPointer: {\r\n              type: 'cross',\r\n              crossStyle: {\r\n                color: '#999'\r\n              }\r\n            }\r\n          },\r\n          legend: {\r\n            data: ['进步得分', '进步率'],\r\n            left: 'center',\r\n            top: 'bottom',\r\n          },\r\n\r\n          xAxis: [\r\n            {\r\n              type: 'category',\r\n              data: ['第一周', '第二周', '第三周', '第四周', '第五周', '第六周', '第七周', '第八周'],\r\n              axisPointer: {\r\n                type: 'shadow'\r\n              }\r\n            }\r\n          ],\r\n          yAxis: [\r\n            {\r\n              type: 'value',\r\n              name: '进步得分',\r\n              min: -100,\r\n              max: 100,\r\n              interval: 20,\r\n              axisLabel: {\r\n                formatter: '{value} '\r\n              }\r\n            },\r\n            {\r\n              type: 'value',\r\n              name: '得分率',\r\n              min: -100,\r\n              max: 100,\r\n              interval: 20,\r\n              axisLabel: {\r\n                formatter: '{value} %'\r\n              }\r\n            }\r\n          ],\r\n          series: [\r\n            {\r\n              name: '进步得分',\r\n              type: 'bar',\r\n              tooltip: {\r\n                valueFormatter: function (value) {\r\n                  return value;\r\n                }\r\n              },\r\n              data: [\r\n                10, 20, 30, 50, 60, 20, 20, 20\r\n              ]\r\n            },\r\n            {\r\n              name: '进步率',\r\n              type: 'line',\r\n              yAxisIndex: 1,\r\n              tooltip: {\r\n                valueFormatter: function (value) {\r\n                  return value * 100 + ' %';\r\n                }\r\n              },\r\n              data: [10, 20, 30, -10, -40, -50, 60, -50]\r\n            }\r\n          ]\r\n        }\r\n      )\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n\r\n\r\n"],"mappings":";;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAP,OAAA,CAAAQ,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA,CACA;QACAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;UACAC,WAAA;YACAC,IAAA;YACAC,UAAA;cACAC,KAAA;YACA;UACA;QACA;QACAC,MAAA;UACAnB,IAAA;UACAY,IAAA;UACAQ,GAAA;QACA;QAEAC,KAAA,GACA;UACAL,IAAA;UACAhB,IAAA;UACAe,WAAA;YACAC,IAAA;UACA;QACA,EACA;QACAM,KAAA,GACA;UACAN,IAAA;UACAjB,IAAA;UACAwB,GAAA;UACAC,GAAA;UACAC,QAAA;UACAC,SAAA;YACAC,SAAA;UACA;QACA,GACA;UACAX,IAAA;UACAjB,IAAA;UACAwB,GAAA;UACAC,GAAA;UACAC,QAAA;UACAC,SAAA;YACAC,SAAA;UACA;QACA,EACA;QACAC,MAAA,GACA;UACA7B,IAAA;UACAiB,IAAA;UACAH,OAAA;YACAgB,cAAA,WAAAA,eAAAC,KAAA;cACA,OAAAA,KAAA;YACA;UACA;UACA9B,IAAA,GACA;QAEA,GACA;UACAD,IAAA;UACAiB,IAAA;UACAe,UAAA;UACAlB,OAAA;YACAgB,cAAA,WAAAA,eAAAC,KAAA;cACA,OAAAA,KAAA;YACA;UACA;UACA9B,IAAA;QACA;MAEA,EACA;MACAgC,MAAA,CAAAC,gBAAA;QACA5B,OAAA,CAAA6B,MAAA;MACA;IACA;EACA;AACA"}]}