wLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('main9'))\n      // 绘制图表\n      myChart.setOption({\n\n        title: {\n          text: '课业完成情况雷达图',\n          left: 'center'\n        },\n        legend: {\n          left: 'center',\n          top: 'bottom',\n          data: ['个人学情']\n        },\n        radar: {\n          // shape: 'circle',\n          indicator: [\n            { name: '到课率', max: 100 },\n            { name: '任务点完成率', max: 100 },\n            { name: '课堂活动参与率', max: 100 },\n            { name: '作业完成率', max: 100 },\n            { name: '讨论参与度', max: 100 },\n            { name: '个人总评', max: 100 }\n          ],\n          name: { // (圆外的标签)雷达图每个指示器名称的配置项。\n\n            textStyle: {\n              fontSize: 13,\n              color: 'black'\n            }\n          },\n\n        },\n        series: [\n          {\n            name: 'Budget vs spending',\n            type: 'radar',\n            label: {  //显示value中具体的数值\n\n              show: true,\n              extStyle: {  //更改数值样式\n                color: 'blue'\n              }\n\n            },\n            data: [\n              {\n                value: [42, 30, 35, 85, 62, 92],\n                name: '个人学情',\n                areaStyle: { color: \"#a9d4f6\" }, //阴影背景颜色\n                lineStyle: {\n                  color: \"#4890ff\",\n                  // 阴影折线宽度\n                  width: 1\n                },\n\n              }\n            ]\n          }\n        ]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"],"mappings":";;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAP,OAAA,CAAAQ,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA;QAEAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;Q