      msg: 'Welcome to Your Vue.js App'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.drawLine()\r\n  },\r\n  methods: {\r\n    drawLine() {\r\n      // 基于准备好的dom，初始化echarts实例\r\n      var myChart = echarts.init(document.getElementById('ana1'))\r\n      // 绘制图表\r\n      myChart.setOption({\r\n        title: {\r\n          text: '学生对该课程偏好度',\r\n          left: 'center'\r\n        },\r\n        tooltip: {\r\n          trigger: 'item',\r\n          formatter(e) {\r\n            return `${e.name}的学生人数为 : ${e.data.values}`//将他动态设置 name就是名字 values是我给他新添加的真实数据\r\n          }\r\n        },\r\n        legend: {\r\n          data: ['厌倦这门课', '疲于接受这门课', '能接受这门课', '喜欢这门课', '热爱这门课',],\r\n          left: 'center',\r\n          top: 'bottom',\r\n        },\r\n        series: [\r\n          {\r\n            name: 'prefer',\r\n            type: 'funnel',\r\n            left: '10%',\r\n            top: 60,\r\n            bottom: 60,\r\n            width: '80%',\r\n            min: 0,\r\n            max: 100,\r\n            minSize: '0%',\r\n            maxSize: '100%',\r\n            sort: 'ascending',\r\n            gap: 2,\r\n            label: {\r\n              show: true,\r\n              position: 'inside',\r\n              formatter(e) {\r\n                return `${e.data.values}`\r\n              },\r\n            },\r\n            labelLine: {\r\n              length: 10,\r\n              lineStyle: {\r\n                width: 1,\r\n                type: 'solid'\r\n              }\r\n            },\r\n            itemStyle: {\r\n              borderColor: '#fff',\r\n              borderWidth: 1\r\n            },\r\n            emphasis: {\r\n              label: {\r\n                fontSize: 20\r\n              }\r\n            },\r\n            data: [\r\n              { value: 20, name: '厌倦这门课', values: 2 },\r\n              { value: 40, name: '疲于接受这门课', values: 2 },\r\n              { value: 60, name: '能接受这门课', values: 20 },\r\n              { value: 80, name: '喜欢这门课', values: 1 },\r\n              { value: 100, name: '热爱这门课', values: 4 }\r\n            ]\r\n          }\r\n        ]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n"],"mappings":";;;;;;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAP,OAAA,CAAAQ,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA;QACAC,KAAA;UACAC,IAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;UACAC,SAAA,WAAAA,UAAAC,CAAA;YACA,UAAAC,MAAA,CAAAD,CAAA,CAAAjB,IAAA,6CAAAkB,MAAA,CAAAD,CAAA,CAAAhB,IAAA,CAAAkB,MAAA;UACA;QACA;;QACAC,MAAA;UACAnB,IAAA;UACAY,IAAA;UACAQ,GAAA;QACA;QACAC,MAAA,GACA;UACAtB,IAAA;UACAuB,IAAA;UACAV,IAAA;UACAQ,GAAA;UACAG,MAAA;UACAC,KAAA;UACAC,GAAA;UACAC,GAAA;UACAC,OAAA;UACAC,OAAA;UACAC,IAAA;UACAC,GAAA;UACAC,KAAA;YACAC,IAAA;YACAC,QAAA;YACAlB,SAAA,WAAAA,UAAAC,CAAA;cACA,UAAAC,MAAA,CAAAD,CAAA,CAAAhB,IAAA,CAAAkB,MAAA;YACA;UACA;UACAgB,SAAA;YACAC,MAAA;YACAC,SAAA;cACAZ,KAAA;cACAF,IAAA;YACA;UACA;UACAe,SAAA;YACAC,WAAA;YACAC,WAAA;UACA;UACAC,QAAA;YACAT,KAAA;cACAU,QAAA;YACA;UACA;UACAzC,IAAA,GACA;YAAA0C,KAAA;YAAA3C,IAAA;YAAAmB,MAAA;UAAA,GACA;YAAAwB,KAAA;YAAA3C,IAAA;YAAAmB,MAAA;UAAA,GACA;YAAAwB,KAAA;YAAA3C,IAAA;YAAAmB,MAAA;UAAA,GACA;YAAAwB,KAAA;YAAA3C,IAAA;YAAAmB,MAAA;UAAA,GACA;YAAAwB,KAAA;YAAA3C,IAAA;YAAAmB,MAAA;UAAA;QAEA;MAEA;MACAyB,MAAA,CAAAC,gBAAA;QACAvC,OAAA,CAAAwC,MAAA;MACA;IACA;EACA;AACA"}]}