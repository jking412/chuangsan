 true,\r\n              fontSize: 30,\r\n              formatter: function () {\r\n                return (data * 100).toFixed(0) + '%'; // 标签内容，显示数据占比\r\n              }\r\n            }\r\n          }]\r\n        }\r\n      )\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n"],"mappings":";;;;;;;;AAMA,YAAAA,OAAA;AACA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,QAAA;EACA;EACAC,OAAA;IACAD,QAAA,WAAAA,SAAA;MACA;MACA,IAAAE,OAAA,GAAAP,OAAA,CAAAQ,IAAA,CAAAC,QAAA,CAAAC,cAAA;MACA;MACAH,OAAA,CAAAI,SAAA,CACA;QACAC,KAAA;UACAC,IAAA;UACAC,SAAA,EAAAC,eAAA;YAEAC,UAAA;YACAC,KAAA;UAAA,iBACA,OACA;UACAC,CAAA;UACAC,CAAA;QACA;QACAC,OAAA;UACAC,IAAA;UACAC,IAAA;UACAC,GAAA;UACAC,QAAA;YACAH,IAAA;YACAI,CAAA;YACAH,IAAA;YACAC,GAAA;YACAG,KAAA;cACAC,IAAA;cACAd,IAAA;cACAe,IAAA;cACAC,SAAA;YACA;UACA;QACA;QAEAC,MAAA;UACAT,IAAA;UACAnB,IAAA;UACA6B,MAAA;UAAA;UACAC,SAAA;UAAA;UACAf,KAAA;YACAI,IAAA;YACAH,CAAA;YACAC,CAAA;YACAc,EAAA;YACAC,EAAA;YACAC,UAAA;cACAC,MAAA;cACAnB,KAAA;YACA;cACAmB,MAAA;cACAnB,KAAA;YACA;;YACAoB,MAAA;UACA;;UACAC,OAAA;YACAC,IAAA;UACA;UAAA;UACAC,eAAA;YACAvB,KAAA;UACA;UAAA;UACAwB,KAAA;YACAF,IAAA;YACAG,QAAA;YACAC,SAAA,WAAAA,UAAA;cACA,QAAAzC,IAAA,QAAA0C,OAAA;YACA;UACA;QACA;MACA,EACA;;MACAC,MAAA,CAAAC,gBAAA;QACAvC,OAAA,CAAAwC,MAAA;MACA;IACA;EACA;AACA"}]}