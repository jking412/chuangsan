t: 'center'\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'cross',\n            crossStyle: {\n              color: '#999'\n            }\n          }\n        },\n        legend: {\n          data: ['已到人数', '未到人数', '到课率'],\n          left: 'center',\n          top: 'bottom',\n        },\n        dataZoom: [\n          {\n            type: \"inside\",\n            xAxisIndex: [0],\n            show: true,\n            startValue: 0, // 从头开始\n            endValue: 3, // 一次性展示几个\n          },\n        ],\n\n        xAxis: [\n          {\n            type: 'category',\n            name: '课程节次',\n            data: that.dataxAxis,\n            axisPointer: {\n              type: 'shadow',\n            },\n\n            axisLabel: {\n              interval: 0,//代表显示所有x轴标签显示\n            },\n            nameLocation: \"middle\",\n\n          }\n        ],\n        yAxis: [\n          {\n            type: 'value',\n            boundaryGap: [0, 0.01],\n            name: '人数',\n            min: 0,\n            max: 100,\n            interval: 20,\n            axisLabel: {\n              formatter: '{value} '\n            },\n\n          },\n          {\n            type: 'value',\n            name: '到课率',\n            min: 0,\n            max: 100,\n            interval: 20,\n            axisLabel: {\n              formatter: '{value}%'\n            },\n\n          }\n        ],\n        series: [\n          {\n            name: '已到人数',\n            type: 'bar',\n            tooltip: {\n              valueFormatter: function (value) {\n                return value;\n              }\n            },\n\n            data: data[0],\n            barWidth: 20,\n            itemStyle: {\n              normal: {\n                color: {\n                  type: 'linear',\n                  x: 0,\n                  y: 0,\n                  x2: 0,\n                  y2: 1,\n                  colorStops: [\n                    {