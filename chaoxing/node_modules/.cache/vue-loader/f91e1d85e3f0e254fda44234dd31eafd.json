data() {\r\n    return {\r\n      data: {\r\n        value: [{\r\n          \"name\": \"堰流\",\r\n          \"value\": 1446\r\n        },\r\n        {\r\n          \"name\": '静压强及其特性',\r\n          \"value\": 928\r\n        },\r\n        {\r\n          \"name\": \"液体运动的描述方法\",\r\n          \"value\": 906\r\n        },\r\n        {\r\n          \"name\": \"液流阻力和水头损失分类及计算公式\",\r\n          \"value\": 825\r\n        },\r\n        {\r\n          \"name\": \"量纲和谐原理\",\r\n          \"value\": 514\r\n        },\r\n        {\r\n          \"name\": \"水力学的发展简史\",\r\n          \"value\": 486\r\n        },\r\n        {\r\n          \"name\": \"液体的平衡微分方程\",\r\n          \"value\": 53\r\n        },\r\n        {\r\n          \"name\": \"液体流动的类型\",\r\n          \"value\": 163\r\n        },\r\n        {\r\n          \"name\": \"短管恒定岀流\",\r\n          \"value\": 86\r\n        },\r\n        {\r\n          \"name\": \"重力场中静压强分布规律\",\r\n          \"value\": 17\r\n        },\r\n        {\r\n          \"name\": \"描述液体运动的基本概念\",\r\n          \"value\": 6\r\n        },\r\n        {\r\n          \"name\": \"流动相似原理\",\r\n          \"value\": 1\r\n        },\r\n        {\r\n          \"name\": \"液体的力学模型\",\r\n          \"value\": 1437\r\n        },\r\n        {\r\n          \"name\": \"静水压强的量测及分布图\",\r\n          \"value\": 422\r\n        },\r\n        {\r\n          \"name\": \"液体的连续性方程\",\r\n          \"value\": 353\r\n        },\r\n        {\r\n          \"name\": \"作用在液体上的力\",\r\n          \"value\": 331\r\n        },\r\n        {\r\n          \"name\": \"作用在平面上的静水总压力\",\r\n          \"value\": 313\r\n        },\r\n        {\r\n          \"name\": \"理想液体运动的微分方程\",\r\n          \"value\": 307\r\n        },\r\n        {\r\n          \"name\": \"恒定总流动量方程\",\r\n          \"value\": 43\r\n        },\r\n        {\r\n          \"name\": \"简单长管水力计算\",\r\n          \"value\": 15\r\n        },\r\n\r\n        ],\r\n        image: \"data:image/png;base64,\"\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.drawLine()\r\n  },\r\n  methods: {\r\n    drawLine() {\r\n      // 基于准备好的dom，初始化echarts实例\r\n      let that = this\r\n      console.log(that.data);\r\n      var myChart = echarts.init(document.getElementById('ana5'));\r\n      var maskImage = new Image();\r\n      maskImage.src = that.data.image;\r\n      // 绘制图表\r\n      maskImage.onload = function () {\r\n        myChart.setOption(\r\n          {\r\n            series: [{\r\n              type: 'wordCloud',\r\n              layoutAnimation: true,\r\n              maskImage: maskImage,\r\n              sizeRange: [30, 100],\r\n              rotationRange: [0, 0],\r\n              rotationStep: 45,\r\n              gridSize: 8,\r\n              shape: 'pentagon',\r\n              width: '100%',\r\n              height: '100%',\r\n              textStyle: {\r\n                color: function () {\r\n                  return 'rgb(' + [\r\n                    Math.round(Math.random() * 160),\r\n                    Math.round(Math.random() * 160),\r\n                    Math.round(Math.random() * 160)\r\n                  ].join(',') + ')';\r\n                },\r\n                fontFamily: 'sans-serif',\r\n                fontWeight: 'normal',\r\n                emphasis: {\r\n                  shadowBlur: 10,\r\n                  shadowColor: '#333'\r\n                }\r\n              },\r\n              data: that.data.value,\r\n\r\n            }]\r\n          }\r\n        );\r\n        window.addEventListener('resize', function () {\r\n          myChart.resize()\r\n        });\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n\r\n\r\n"]}]}