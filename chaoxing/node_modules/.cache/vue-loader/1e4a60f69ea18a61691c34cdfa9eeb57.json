{"remainingRequest":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\src\\views\\teacher\\boardone\\Maps\\Class_arrival.vue?vue&type=script&lang=js&","dependencies":[{"path":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\src\\views\\teacher\\boardone\\Maps\\Class_arrival.vue","mtime":1680698568441},{"path":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1680431838417},{"path":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\node_modules\\babel-loader\\lib\\index.js","mtime":1680431839031},{"path":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1680431838417},{"path":"E:\\服务外包\\chaoxing\\chaoxing\\front-web\\chaoxing\\node_modules\\vue-loader\\lib\\index.js","mtime":1680431832423}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Class_arrival.vue"],"names":[],"mappings":";;;;;;AAMA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Class_arrival.vue","sourceRoot":"src/views/teacher/boardone/Maps","sourcesContent":["\n<template>\n  <div id=\"boa4\" style=\"width: 100%;height:100%;\" @mouseover=\"mouseOver\" @mouseleave=\"mouseLeave\"></div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nexport default {\n  name: 'Aosa',\n  data() {\n    return {\n      timer: 0,\n      option: 0,\n      myChart: 0,\n      seriesData: [\n        [\n          85, 62, 95, 74, 85, 65, 78, 72\n        ],\n        [\n          87, 62, 95, 66, 55, 33, 44, 22\n        ],\n        [10, 20, 10, 40, 50, 10, 30, 60]\n      ],\n      datax: 0,\n      dataxAxis: 0\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  beforeDestroy() {\n    clearInterval(this.timer)\n  },\n  methods: {\n    mouseOver() {\n\n      clearInterval(this.timer)\n    },\n    mouseLeave() {\n      let that = this\n      this.timer = setInterval(function () {\n        // 每次向左滑动一个，最后一个从头开始。\n        if (that.datax[0][0] == that.seriesData[0][that.seriesData[0].length]) {\n          that.datax = that.seriesData\n        } else {\n          for (let i = 0; i < that.datax.length; i++) {\n            let tem1 = that.datax[i].shift(0, 1);\n            that.datax[i].push(tem1);\n          }\n          let tem2 = that.dataxAxis.shift(0, 1);\n          that.dataxAxis.push(tem2);\n        }\n        that.myChart.setOption(that.option);\n      }, 1500);\n    },\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      let that = this\n      this.myChart = echarts.init(document.getElementById('boa4'))\n      that.datax = that.seriesData\n      that.dataxAxis = [1, 2, 3, 4, 5, 6, 7, 8]\n      let data = that.datax\n\n      // 绘制图表\n      this.option = {\n\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'cross',\n            crossStyle: {\n              color: '#999'\n            }\n          }\n        },\n        legend: {\n          data: ['已到人数', '未到人数', '到课率'],\n          left: 'center',\n          top: 'bottom',\n        },\n        dataZoom: [\n          {\n            type: \"inside\",\n            xAxisIndex: [0],\n            show: true,\n            startValue: 0, // 从头开始\n            endValue: 3, // 一次性展示几个\n          },\n        ],\n\n        xAxis: [\n          {\n            type: 'category',\n            name: '课程节次',\n            data: that.dataxAxis,\n            axisPointer: {\n              type: 'shadow',\n            },\n\n            axisLabel: {\n              interval: 0,//代表显示所有x轴标签显示\n            },\n            nameLocation: \"middle\",\n\n          }\n        ],\n        yAxis: [\n          {\n            type: 'value',\n            boundaryGap: [0, 0.01],\n            name: '人数',\n            min: 0,\n            max: 100,\n            interval: 20,\n            axisLabel: {\n              formatter: '{value} '\n            },\n\n          },\n          {\n            type: 'value',\n            name: '到课率',\n            min: 0,\n            max: 100,\n            interval: 20,\n            axisLabel: {\n              formatter: '{value}%'\n            },\n\n          }\n        ],\n        series: [\n          {\n            name: '已到人数',\n            type: 'bar',\n            tooltip: {\n              valueFormatter: function (value) {\n                return value;\n              }\n            },\n\n            data: data[0],\n            barWidth: 20,\n            itemStyle: {\n              normal: {\n                color: {\n                  type: 'linear',\n                  x: 0,\n                  y: 0,\n                  x2: 0,\n                  y2: 1,\n                  colorStops: [\n                    { offset: 0, color: '#4890ff' }, // 设置颜色渐变\n                    { offset: 1, color: '#00b6ff' }\n                  ]\n                },\n              }\n            },\n          },\n          {\n            name: '未到人数',\n            type: 'bar',\n            tooltip: {\n              valueFormatter: function (value) {\n                return value;\n              }\n            },\n\n            data: data[1],\n            barWidth: 20,\n            itemStyle: {\n              normal: {\n                // color: {\n                //   type: 'linear',\n                //   x: 0,\n                //   y: 0,\n                //   x2: 0,\n                //   y2: 1,\n                //   colorStops: [\n                //     { offset: 0, color: '#f9d423' }, // 设置颜色渐变\n                //     { offset: 1, color: '#ff4e50' }\n                //   ]\n                // },\n                color: \"#f13e3c\"\n              }\n            },\n          },\n          {\n            name: '到课率',\n            type: 'line',\n            color: 'black',\n            showSymbol: false,\n            yAxisIndex: 1,\n            tooltip: {\n              valueFormatter: function (value) {\n                return value + ' %';\n              }\n            },\n            data: data[2],\n            barWidth: 40\n          }\n        ]\n      };\n      this.timer = setInterval(function () {\n        // 每次向左滑动一个，最后一个从头开始。\n        if (that.datax[0][0] == that.seriesData[0][that.seriesData[0].length]) {\n          that.datax = that.seriesData\n        } else {\n          for (let i = 0; i < that.datax.length; i++) {\n            let tem1 = that.datax[i].shift(0, 1);\n            that.datax[i].push(tem1);\n          }\n          let tem2 = that.dataxAxis.shift(0, 1);\n          that.dataxAxis.push(tem2);\n        }\n        that.myChart.setOption(that.option);\n      }, 1500);\n      that.myChart.setOption(this.option)\n      window.addEventListener('resize', function () {\n        that.myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n"]}]}