始化echarts实例\r\n      var myChart = echarts.init(document.getElementById('main3'))\r\n      // 绘制图表\r\n      myChart.setOption({\r\n        title: {\r\n          text: '各课程完成情况',\r\n          left: 'center'\r\n        },\r\n        tooltip: {\r\n          trigger: 'axis',\r\n          axisPointer: {\r\n            type: 'shadow'\r\n          }\r\n        },\r\n        legend: {\r\n          left: 'center',\r\n          top: 'bottom',\r\n        },\r\n        grid: {\r\n          left: '3%',\r\n          right: '4%',\r\n          bottom: '5%',\r\n          containLabel: true\r\n        },\r\n        xAxis: {\r\n          type: 'value',\r\n          boundaryGap: [0, 0.01]\r\n        },\r\n        yAxis: {\r\n          type: 'category',\r\n          data: ['旅游学概论', '产业经济学', '财务管理', '水力学', '农业气象学', '数据结构', '离散数学']\r\n        },\r\n        series: [\r\n          {\r\n            name: '已完成任务点',\r\n            type: 'bar',\r\n            data: [12,\r\n              {\r\n                value: 30, itemStyle: {\r\n                  shadowColor: '#fd0000',\r\n                  shadowBlur: 10,\r\n                  borderColor: 'rgba(255, 255, 0,0.9)',\r\n                  borderWidth: 1\r\n                }\r\n              },\r\n              42, 35, 43, 42, 11],\r\n\r\n          },\r\n          {\r\n            name: '总任务点',\r\n            type: 'bar',\r\n            data: [20, {\r\n              value: 30, itemStyle: {\r\n                shadowColor: '#fd0000',\r\n                shadowBlur: 10,\r\n                borderColor: 'rgba(255, 255, 0,0.9)',\r\n                borderWidth: 1\r\n              }\r\n            }, 45, 40, 45, 50, 20]\r\n          }\r\n        ]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n"]}]}