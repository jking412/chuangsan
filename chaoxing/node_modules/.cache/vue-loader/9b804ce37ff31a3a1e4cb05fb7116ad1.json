   myChart.setOption({\r\n        title: {\r\n          text: '10%',\r\n          textStyle: {\r\n\r\n            fontWeight: 'normal',\r\n            color: '#fff',\r\n            fontWeight: 'bold',\r\n          },\r\n          x: 'center',\r\n          y: '35%'\r\n        },\r\n        graphic: [{\r\n          type: 'group',\r\n          left: 'center',\r\n          top: '50%',\r\n          children: [{\r\n            type: 'text',\r\n            z: 100,\r\n            left: '6',\r\n            top: 'middle',\r\n            style: {\r\n              fill: '#fff',\r\n              text: '挂科率',\r\n              font: '20px'\r\n            }\r\n          }]\r\n        }],\r\n\r\n        series: [{\r\n          type: 'liquidFill',\r\n          data: [0.1, 0.1, 0.1, 0.1],\r\n          radius: '70%', // 水球半径，可以是数值或百分比\r\n          amplitude: 10, // 振幅，影响水波的高度\r\n          color: [{\r\n            type: 'linear',\r\n            x: 0,\r\n            y: 1,\r\n            x2: 0,\r\n            y2: 0,\r\n            colorStops: [{\r\n              offset: 1,\r\n              color: ['#ff0844'], // 0% 处的颜色\r\n            }, {\r\n              offset: 0,\r\n              color: ['#ffb199'], // 100% 处的颜色\r\n            }],\r\n            global: false // 缺省为 false\r\n          }],\r\n          outline: {\r\n            show: false\r\n          }, // 是否显示边框\r\n          backgroundStyle: {\r\n            color: '#e5e5e5'\r\n          }, // 背景颜色\r\n          label: {\r\n            show: false,\r\n          }\r\n        }]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n"]}]}