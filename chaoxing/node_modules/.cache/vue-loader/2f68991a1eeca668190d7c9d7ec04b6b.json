{"remainingRequest":"E:\\chaoxing\\front-web\\chaoxing\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\chaoxing\\front-web\\chaoxing\\src\\views\\student\\dashboard\\Maps\\Radar_chart.vue?vue&type=script&lang=js&","dependencies":[{"path":"E:\\chaoxing\\front-web\\chaoxing\\src\\views\\student\\dashboard\\Maps\\Radar_chart.vue","mtime":1681127680037},{"path":"E:\\chaoxing\\front-web\\chaoxing\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1680431838417},{"path":"E:\\chaoxing\\front-web\\chaoxing\\node_modules\\babel-loader\\lib\\index.js","mtime":1680431839031},{"path":"E:\\chaoxing\\front-web\\chaoxing\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1680431838417},{"path":"E:\\chaoxing\\front-web\\chaoxing\\node_modules\\vue-loader\\lib\\index.js","mtime":1680431832423}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Radar_chart.vue"],"names":[],"mappings":";;;;;;AAMA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Radar_chart.vue","sourceRoot":"src/views/student/dashboard/Maps","sourcesContent":["\n<template>\n  <div id=\"main9\" style=\"width: 100%;height:100%;\"></div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nexport default {\n  name: 'radar',\n  data() {\n    return {\n      msg: 'Welcome to Your Vue.js App'\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('main9'))\n      // 绘制图表\n      myChart.setOption({\n\n        title: {\n          text: '个人学习风格雷达图',\n          left: 'center'\n        },\n        legend: {\n          left: 'center',\n          top: 'bottom',\n          data: ['个人学情']\n        },\n        radar: {\n          // shape: 'circle',\n          indicator: [\n            { name: '到课率', max: 100 },\n            { name: '任务点完成率', max: 100 },\n            { name: '课堂活动参与率', max: 100 },\n            { name: '作业完成率', max: 100 },\n            { name: '讨论参与度', max: 100 },\n            { name: '个人总评', max: 100 }\n          ],\n          AxisName: { // (圆外的标签)雷达图每个指示器名称的配置项。\n            fontSize: 13,\n            color: 'black'\n          },\n        },\n        series: [\n          {\n            name: 'Budget vs spending',\n            type: 'radar',\n            label: {  //显示value中具体的数值\n\n              show: true,\n              extStyle: {  //更改数值样式\n                color: 'blue'\n              }\n\n            },\n            data: [\n              {\n                value: [42, 30, 35, 85, 62, 92],\n                name: '个人学情',\n                areaStyle: { color: \"#a9d4f6\" }, //阴影背景颜色\n                lineStyle: {\n                  color: \"#4890ff\",\n                  // 阴影折线宽度\n                  width: 1\n                },\n\n              }\n            ]\n          }\n        ]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"]}]}