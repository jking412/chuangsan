 #4791fc; font-size: 38px\"><svg-icon icon-class=\"homework\"\n                style=\"color: #409EFF; font-size: 30px\" /> + 22</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart6></chart6>\n          </div>\n        </div>\n        <div class=\"four-card\">\n          <div class=\"basic-word\">\n            <h4 style=\"color: #979797;\">挂科预警分析</h4>\n            <h3 style=\"font-weight: 600\">当前挂科风险: </h3>\n            <h1 style=\"color: red; font-size: 38px\"><svg-icon icon-class=\"warning\"\n                style=\"color: #E65256; font-size: 30px\" /> 10%</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart7></chart7>\n          </div>\n        </div>\n      </div>\n      <div class=\"tasks-card\" style=\"width: 40%\" @mouseover=\"mouseover\" @mouseleave=\"mouseleave\">\n        <div style=\"color: #979797; font-weight: 700; display: flex; align-items: center\">\n          <div style=\"width: 40%;margin-right:8px\">\n            <el-select v-model=\"select.name\" placeholder=\"select\">\n              <el-option v-for=\"item in selects\" :key=\"item.value\" :label=\"item.label\" :value=\"item.value\">\n              </el-option>\n            </el-select>\n          </div>\n          <div style=\"width: 60%; display:flex;align-items: center\">\n            进度<el-progress :percentage=\"select.num\" :stroke-width=\"14\"></el-progress>\n          </div>\n        </div>\n        <div class=\"task-list\">\n          <el-table :data=\"choose()\" style=\"width: 100%;\" height=\"284px\" ref=\"table\">\n            <el-table-column prop=\"name\" label=\"名称\" min-width=\"40%\">\n            </el-table-column>\n            <el-table-column prop=\"status\" label=\"状态\" min-width=\"40%\">\n            </el-table-column>\n            <el-table-column v-if=\"show\" prop=\"score\" label=\"得分\" min-width=\"20%\">\n            </el-table-column>\n          </el-table>\n        </div>\n      </div>\n    </div>\n    <div class=\"downcard1\">\n      <div class=\"downcard1Left\">\n        <chart2></chart2>\n        <el-popover placement=\"top-start\" title=\"你当前的互动度为170\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"order\" slot=\"reference\" style=\"font-size: 35px;\" class=\"icon1\">\n          </svg-icon>\n        </el-popover>\n        <el-popover placement=\"top-start\" title=\"你当前的主要互动行为是：分组任务活动、计时器活动\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"behavior\" slot=\"reference\" style=\"font-size: 35px;\" class=\"icon2\">\n          </svg-icon>\n        </el-popover>\n      </div>\n      <div class=\"downcard1Right\">\n        <chart9></chart9>\n      </div>\n    </div>\n    <div class=\"downcard2\">\n      <div class=\"downcard2Left\">\n        <chart10></chart10>\n      </div>\n      <div class=\"downcard2Right\">\n        <chart11 class=\"tr\"></chart11>\n        <el-popover placement=\"top-start\" title=\"你当前的偏好学科为：水力学、水力学实验方法\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"prefer\" slot=\"reference\" style=\"font-size: 38px;\" class=\"icon3\">\n          </svg-icon>\n        </el-popover>\n        <el-popover placement=\"top-start\" title=\"你当前的学科评价等级为：A\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"score\" slot=\"reference\" style=\"font-size: 38px;\" class=\"icon4\">\n          </svg-icon>\n        </el-popover>\n      </div>\n    </div>\n    <div class=\"downcard3\">\n\n      <el-dialog title=\"个人学情\" :visible.sync=\"centerDialogVisible\" width=\"30%\" center style=\" overflow: hidden;\">\n        <span style=\"font-size: 20px;display: flex;flex-wrap: wrap;justify-content: space-between;align-items: center;\">\n          <div>\n            当前周数：{{ taskpointName }}<br>\n            当前学科评价等级为：<span style=\"color: #dc143c;\">{{ taskpointContain[flag].value3 }}</span><br>\n          </div>\n          <div style=\"width: 100%;height: 300px;\">\n            <el-table :data=\"tableData\" stripe style=\"width: 100%;border-radius: 5px;\" height=\"300px\"\n              :header-cell-style=\"{ background: '#636ebe', color: '#b0c4f7' }\">\n              <el-table-column prop=\"index\" label=\"序号\" />\n              <el-table-column prop=\"class\" label=\"周数\" />\n              <el-table-column prop=\"avg\" label=\"学习效果\" />\n              <el-table-column prop=\"max\" label=\"学习总评\" />\n              <el-table-column prop=\"min\" label=\"班级位次\" />\n            </el-table>\n          </div>\n        </span>\n      </el-dialog>\n      <chart1 @callback=\"callback\"></chart1>\n    </div>\n  </div>\n</template>\n<script>\nimport store from '../../../store'\nimport { arrApi, jobApi, actRateApi, examApi, workApi, bbsApi } from './api'\n\nimport chart1 from './Maps/Analysis_of_student_achievement.vue'\nimport chart2 from './Maps/Class_activities.vue'\nimport chart4 from './Maps/Circle-1.vue'\nimport chart5 from './Maps/Circle-2.vue'\nimport chart6 from './Maps/Circle-3.vue'\nimport chart7 from './Maps/Circle-4.vue'\nimport chart9 from './Maps/Radar_chart'\nimport chart10 from './Maps/Discussion_flow_chart.vue'\nimport chart11 from './Maps/Subject_preference.vue'\nimport chart12 from './Maps/Circle-5.vue'\nexport default {\n  name: 'Dashboard',\n  data() {\n    return {\n      tableData: [\n        {\n          index: '01',\n          class: '第一周',\n          avg: 60,\n          max: 90,\n          min: '前20%'\n        },\n        {\n          index: '02',\n          class: '第二周',\n          avg: 54,\n          max: 84,\n          min: '前40%'\n        },\n        {\n          index: '03',\n          class: '第三周',\n          avg: 71,\n          max: 92,\n          min: '前10%'\n        },\n        {\n          index: '04',\n          class: '第四周',\n          avg: 50,\n          max: 78,\n          min: '前55%'\n        },\n        {\n          index: '05',\n          class: '第五周',\n          avg: 65,\n          max: 88,\n          min: '前30%'\n        },\n        {\n          index: '06',\n          class: '第六周',\n          avg: 71,\n          max: 98,\n          min: '前15%'\n        },\n        {\n          index: '07',\n          class: '第七周',\n          avg: 88,\n          max: 90,\n          min: '前5%'\n        },\n        {\n          index: '08',\n          class: '第八周',\n          avg: 64,\n          max: 61,\n          min: '前50%'\n        },\n      ],\n      centerDialogVisible: false,\n      taskpointName: '',\n      flag: 0,\n      show: true,\n      taskpointContain: [{\n        value1: 65,\n        value2: 85,\n        value3: \"B\",\n        value4: 0.8\n      },\n      {\n        value1: 76,\n        value2: 88,\n        value3: \"A\",\n        value4: 0.9\n      }\n      ],\n      person: {\n        Username: '李四',\n        UserId: 19201080\n      },\n      tasks: [\n        { name: '任务点1', status: '已完成', score: '79' },\n        { name: '任务点2', status: '已完成', score: '96' },\n        { name: '任务点3', status: '已完成', score: '78' },\n        { name: '任务点4', status: '未完成', score: '0' },\n        { name: '任务点5', status: '未完成', score: '0' },\n        { name: '任务点6', status: '未完成', score: '0' },\n        { name: '任务点7', status: '未完成', score: '0' },\n      ],\n      homework: [\n        { name: '作业1', status: '已完成', score: '87' },\n        { name: '作业2', status: '已完成', score: '69' },\n        { name: '作业3', status: '已完成', score: '48' },\n        { name: '作业4', status: '已完成', score: '91' },\n        { name: '作业5', status: '已完成', score: '84' },\n        { name: '作业6', status: '已完成', score: '64' },\n        { name: '作业7', status: '已完成', score: '80' },\n        { name: '作业8', status: '已完成', score: '97' },\n        { name: '作业9', status: '已完成', score: '76' },\n        { name: '作业10', status: '未完成', score: '0' },\n\n      ],\n      exam: [\n        { name: '水力学试卷(1)', status: '已完成', score: '78' },\n        { name: '水力学试卷(2)', status: '已完成', score: '65' },\n        { name: '水力学试卷(3)', status: '已完成', score: '82' },\n        { name: '水力学题库(1)', status: '已完成', score: '87' },\n        { name: '水力学题库(2)', status: '已完成', score: '59' },\n        { name: '水力学与桥涵水文期中考试', status: '已完成', score: '75' },\n        { name: '水力学与桥涵水文期末考试', status: '未进行', score: '0' },\n      ],\n      select: {\n        name: 'homework',\n        num: 20\n      },\n      selects: [{\n        value: 'homework',\n        label: '作业',\n      }, {\n        value: 'exam',\n        label: '考试',\n      }, {\n        value: 'tasks',\n        label: '任务点',\n      }],\n      timer: 0,\n      Info: store.getters.Info,\n      clazzIndex: 0,\n      clazzes: store.getters.Info.clazzes,\n      job: ''\n    }\n  },\n  methods: {\n    callback(data) {\n      this.centerDialogVisible = data[0];\n      this.taskpointName = data[1];\n      if (this.taskpointName == \"第四周\")\n        this.flag = 1\n      else\n        this.flag = 0\n    },\n\n    getright_table() {\n      let isScroll = true\n      var this_ = this\n      this.$nextTick(() => {\n        let t = document.getElementsByClassName(\"el-table__body\")[0];\n        this.timer = setInterval(() => {\n          if (this.select.name === 'homework') {\n            if (isScroll) {\n              var data = this_.homework[0];\n              setTimeout(() => {\n                this_.homework.push(data);\n                t.style.transition = \"all .5s\";\n                t.style.marginTop = \"-47.67px\";\n              }, 500);\n              setTimeout(() => {\n                this_.homework.splice(0, 1);\n                t.style.transition = \"all 0s ease 0s\";\n                t.style.marginTop = \"0\";\n              }, 1000);\n            }\n          }\n          else if (this.select.name === 'exam') {\n            if (isScroll) {\n              var data = this_.exam[0];\n              setTimeout(() => {\n                this_.exam.push(data);\n                t.style.transition = \"all .5s\";\n                t.style.marginTop = \"-47.67px\";\n              }, 500);\n              setTimeout(() => {\n                this_.exam.splice(0, 1);\n                t.style.transition = \"all 0s ease 0s\";\n                t.style.marginTop = \"0\";\n              }, 1000);\n            }\n          }\n          else {\n            if (isScroll) {\n              var data = this_.tasks[0];\n              setTimeout(() => {\n                this_.tasks.push(data);\n                t.style.transition = \"all .5s\";\n                t.style.marginTop = \"-47.67px\";\n              }, 500);\n              setTimeout(() => {\n                this_.tasks.splice(0, 1);\n                t.style.transition = \"all 0s ease 0s\";\n                t.style.marginTop = \"0\";\n              }, 1000);\n            }\n          }\n        }, 2500);\n      });\n    },\n    mouseover() {\n      clearInterval(this.timer)\n    },\n    mouseleave() {\n      this.getright_table()\n    },\n    choose() {\n      if (this.select.name === 'homework') {\n        this.show = true;\n        this.select.num = 90;\n        return this.homework;\n      } else if (this.select.name === 'exam') {\n        this.show = true;\n        this.select.num = 85;\n        return this.exam;\n      } else {\n        this.show = false;\n        this.select.num = 43\n        return this.tasks\n      }\n    },\n    change(index) {\n      this.getJob(index)\n      this.getArr(index)\n      this.getActRate(index)\n      this.getWork(index)\n      this.getExam(index)\n    },\n    getJob(index) {\n      jobApi(this.clazzes[index].course.courseid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getArr(index) {\n      arrApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getActRate(index) {\n      actRateApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getExam(index) {\n      examApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getWork(index) {\n      workApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getBBS() {\n      bbsApi().then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n\n  },\n  mounted() {\n    this.getright_table();\n  },\n  beforeDestroy() {\n    clearInterval(this.timer)\n  },\n  components: {\n    chart1,\n    chart2,\n    chart4,\n    chart5,\n    chart6,\n    chart7,\n    chart9,\n    chart10,\n    chart11,\n    chart12\n  }\n}\n</script>\n\n<style lang=\"scss\">\n.el-dialog {\n  border-radius: 20px;\n}\n</style>\n\n<style lang=\"scss\" scoped>\n.dashboard {\n  &-container {\n    margin: 30px;\n  }\n}\n\n.el-table {\n  font-family: PR;\n  /* 继承全局字体样式 */\n}\n\n.dashboard-container .up-card {\n  display: flex;\n  width: 100%;\n  justify-content: space-between;\n}\n\n@keyframes jump {\n  0% {\n    transform: translate(0px, 0px);\n  }\n\n  50% {\n    transform: translate(0px, -10px);\n  }\n\n  100% {\n    transform: translate(0px, 0px);\n  }\n}\n\n.dashboard-container .up-card .select {\n  height: 6vh;\n  width: 100%;\n}\n\n.dashboard-container .up-card .basic-card {\n  display: flex;\n  width: 58%;\n  height: 42vh;\n  flex-wrap: wrap;\n  justify-content: space-between;\n  align-content: space-between;\n}\n\n.dashboard-container .up-card .basic-card .four-card {\n  width: 48%;\n  height: 20vh;\n  border-radius: 20px;\n  background-color: #fff;\n  overflow: hidden;\n  display: flex;\n  transition-duration: 0.3s;\n}\n\n.dashboard-container .up-card .basic-card .four-card:hover {\n  cursor: pointer;\n  box-shadow: 0 10px 10px -10px rgba(0, 0, 0, 0.5);\n  transform: scale(1.1);\n}\n\n.dashboard-container .up-card .basic-card .four-card .basic-word {\n  width: 50%;\n  height: 100%;\n  padding: 15px 0px 0px 35px;\n}\n\n.dashboard-container .up-card .basic-card .four-card .basic-chart {\n  width: 50%;\n  height: 100%;\n}\n\n.dashboard-container .up-card .tasks-card {\n  width: 38%;\n  padding: 20px;\n  height: 42vh;\n  border-radius: 20px;\n  margin: 0px 0px 20px 0px;\n  background-color: #fff;\n  transition-duration: 0.3s;\n  display: flex;\n  flex-direction: column;\n}\n\n.dashboard-container .up-card .tasks-card:hover {\n  cursor: pointer;\n  box-shadow: 0 10px 10px -10px rgba(0, 0, 0, 0.5);\n  transform: scale(1.1);\n}\n\n.dashboard-container .up-card .tasks-card .el-progress {\n  margin-left: 1em;\n  width: 80%;\n}\n\n.dashboard-container .up-card .tasks-card .task-list {\n  margin-top: 10px;\n  width: 100%;\n  height: 30vh;\n  overflow: hidden;\n}\n\n.downcard1 {\n  display: flex;\n  width: 100%;\n  height: 50vh;\n  justify-content: space-between;\n  margin-top: 15px;\n}\n\n.downcard1 .downcard1Left {\n  position: relative;\n  display: flex;\n  width: 47.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard1 .downcard1Right {\n  display: flex;\n  width: 50.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 {\n  display: flex;\n  width: 100%;\n  height: 50vh;\n  justify-content: space-between;\n  margin-top: 30px;\n}\n\n.downcard2 .downcard2Left {\n  display: flex;\n  width: 47.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 .downcard2Right {\n  display: flex;\n  width: 50.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 .downcard2Right .tr {\n  transform: translateX(5%);\n}\n\n//#region\n// .dashboard-container .down-card .contain {\n//   width: 750px;\n//   height: 450px;\n//   background-color: #fff