t default {\n  name: 'Aosa',\n  data() {\n    return {\n      msg: 'Welcome to Your Vue.js App'\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('boa5'))\n      var x = 2\n      // 绘制图表\n      let data = [\n        {\n          name: \"1\",\n          value: [0, 0, 9],\n        },\n        {\n          name: \"b\",\n          value: [0, 1, 4],\n        }, {\n          name: \"c\",\n          value: [0, 2, 8],\n        }, {\n          name: \"d\",\n          value: [x, 0, 7],\n        }, {\n          name: \"e\",\n          value: [x, 1, 6],\n        }, {\n          name: \"f\",\n          value: [x, 2, 5],\n        },\n        {\n          name: \"g\",\n          value: [1, 0, 10],\n        }, {\n          name: \"h\",\n          value: [1, 1, 1],\n        }, {\n          name: \"i\",\n          value: [1, 2, 60],\n        },\n        {\n          name: \"j\",\n          value: [1, 3, 990],\n        },\n      ];\n      myChart.setOption({\n        title: {\n          text: '任务点完成情况',\n          left: 'center'\n        },\n        tooltip: {\n          position: 'top'\n        },\n        grid: {\n          height: '50%',\n          top: '10%'\n        },\n        xAxis: {\n          type: 'category',\n          axisLine: {\n            show: false, //隐藏y轴\n          },\n          axisTick: {\n            show: false,  //刻度线\n          },\n          axisLabel: {\n            show: false, //隐藏刻度值\n          },\n        },\n        yAxis: {\n          type: 'category',\n          axisLine: {\n            show: false, //隐藏y轴\n          },\n          axisTick: {\n            show: false,  //刻度线\n          },\n          axisLabel: {\n            show: false, //隐藏刻度值\n          },\n        },\n        visualMap: {\n          min: 0,\n          max: 10,\n          calculable: true,\n          orient: 'horizontal',\n          left: 'center',\n          bottom: '15%'\n        },\n        series: [\n          {\n            name: '任务点完成人数',\n            type: 'heatmap',\n            data: data,\n            label: {\n              show: true,\n              formatter: '{b}'\n            },\n            emphasis: {\n              itemStyle: {\n                shadowBlur: 10,\n                shadowColor: 'rgba(0, 0, 0, 0.5)'\n              }\n            }\n          }\n        ]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"]}]}