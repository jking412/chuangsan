   return {\r\n      msg: 'Welcome to Your Vue.js App'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.drawLine()\r\n  },\r\n  methods: {\r\n    drawLine() {\r\n      // 基于准备好的dom，初始化echarts实例\r\n      var myChart = echarts.init(document.getElementById('boa5'))\r\n      var x = 2\r\n      // 绘制图表\r\n      let data = [\r\n        {\r\n          name: \"1\",\r\n          value: [0, 0, 9],\r\n        },\r\n        {\r\n          name: \"b\",\r\n          value: [0, 1, 4],\r\n        }, {\r\n          name: \"c\",\r\n          value: [0, 2, 8],\r\n        }, {\r\n          name: \"d\",\r\n          value: [x, 0, 7],\r\n        }, {\r\n          name: \"e\",\r\n          value: [x, 1, 6],\r\n        }, {\r\n          name: \"f\",\r\n          value: [x, 2, 5],\r\n        },\r\n        {\r\n          name: \"g\",\r\n          value: [1, 0, 10],\r\n        }, {\r\n          name: \"h\",\r\n          value: [1, 1, 1],\r\n        }, {\r\n          name: \"i\",\r\n          value: [1, 2, 60],\r\n        },\r\n        {\r\n          name: \"j\",\r\n          value: [1, 3, 990],\r\n        },\r\n      ];\r\n      myChart.setOption({\r\n        title: {\r\n          text: '任务点完成情况',\r\n          left: 'center'\r\n        },\r\n        tooltip: {\r\n          position: 'top'\r\n        },\r\n        grid: {\r\n          height: '50%',\r\n          top: '10%'\r\n        },\r\n        xAxis: {\r\n          type: 'category',\r\n          axisLine: {\r\n            show: false, //隐藏y轴\r\n          },\r\n          axisTick: {\r\n            show: false,  //刻度线\r\n          },\r\n          axisLabel: {\r\n            show: false, //隐藏刻度值\r\n          },\r\n        },\r\n        yAxis: {\r\n          type: 'category',\r\n          axisLine: {\r\n            show: false, //隐藏y轴\r\n          },\r\n          axisTick: {\r\n            show: false,  //刻度线\r\n          },\r\n          axisLabel: {\r\n            show: false, //隐藏刻度值\r\n          },\r\n        },\r\n        visualMap: {\r\n          min: 0,\r\n          max: 10,\r\n          calculable: true,\r\n          orient: 'horizontal',\r\n          left: 'center',\r\n          bottom: '15%'\r\n        },\r\n        series: [\r\n          {\r\n            name: '任务点完成人数',\r\n            type: 'heatmap',\r\n            data: data,\r\n            label: {\r\n              show: true,\r\n              formatter: '{b}'\r\n            },\r\n            emphasis: {\r\n              itemStyle: {\r\n                shadowBlur: 10,\r\n                shadowColor: 'rgba(0, 0, 0, 0.5)'\r\n              }\r\n            }\r\n          }\r\n        ]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n\r\n\r\n"]}]}