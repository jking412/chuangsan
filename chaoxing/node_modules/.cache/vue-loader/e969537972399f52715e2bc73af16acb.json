\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('main1'))\n      // 绘制图表\n      myChart.setOption(\n        {\n          title: {\n            text: '学习进步情况',\n            left: 'center'\n          },\n          tooltip: {\n            trigger: 'axis',\n            axisPointer: {\n              type: 'cross',\n              crossStyle: {\n                color: '#999'\n              }\n            }\n          },\n          legend: {\n            data: ['进步得分', '进步率'],\n            left: 'center',\n            top: 'bottom',\n          },\n\n          xAxis: [\n            {\n              type: 'category',\n              data: ['第一周', '第二周', '第三周', '第四周', '第五周', '第六周', '第七周', '第八周'],\n              axisPointer: {\n                type: 'shadow'\n              }\n            }\n          ],\n          yAxis: [\n            {\n              type: 'value',\n              name: '进步得分',\n              min: -100,\n              max: 100,\n              interval: 20,\n              axisLabel: {\n                formatter: '{value} '\n              }\n            },\n            {\n              type: 'value',\n              name: '得分率',\n              min: -100,\n              max: 100,\n              interval: 20,\n              axisLabel: {\n                formatter: '{value} %'\n              }\n            }\n          ],\n          series: [\n            {\n              name: '进步得分',\n              type: 'bar',\n              tooltip: {\n                valueFormatter: function (value) {\n                  return value;\n                }\n              },\n              data: [\n                10, 20, 30, 50, 60, 20, 20, 20\n              ]\n            },\n            {\n              name: '进步率',\n              type: 'line',\n              yAxisIndex: 1,\n              tooltip: {\n                valueFormatter: function (value) {\n                  return value + ' %';\n                }\n              },\n              data: [10, 20, 30, -10, -40, -50, 60, -50]\n            }\n          ]\n        }\n      )\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"]}]}