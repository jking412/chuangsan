      // 绘制图表\r\n      myChart.setOption({\r\n\r\n        title: {\r\n          text: '课业完成情况雷达图',\r\n          left: 'center'\r\n        },\r\n        legend: {\r\n          left: 'center',\r\n          top: 'bottom',\r\n          data: ['个人学情']\r\n        },\r\n        radar: {\r\n          // shape: 'circle',\r\n          indicator: [\r\n            { name: '到课率', max: 100 },\r\n            { name: '任务点完成率', max: 100 },\r\n            { name: '课堂活动参与率', max: 100 },\r\n            { name: '作业完成率', max: 100 },\r\n            { name: '讨论参与度', max: 100 },\r\n            { name: '个人总评', max: 100 }\r\n          ],\r\n          name: { // (圆外的标签)雷达图每个指示器名称的配置项。\r\n\r\n            textStyle: {\r\n              fontSize: 13,\r\n              color: 'black'\r\n            }\r\n          },\r\n\r\n        },\r\n        series: [\r\n          {\r\n            name: 'Budget vs spending',\r\n            type: 'radar',\r\n            label: {  //显示value中具体的数值\r\n\r\n                show: true,\r\n                extStyle: {  //更改数值样式\r\n                  color: 'blue'\r\n                }\r\n\r\n            },\r\n            data: [\r\n              {\r\n                value: [42, 30, 35, 85, 62, 92],\r\n                name: '个人学情',\r\n                areaStyle: { color: \"#a9d4f6\" }, //阴影背景颜色\r\n                lineStyle: {\r\n                  color: \"#4890ff\",\r\n                  // 阴影折线宽度\r\n                  width: 1\r\n                },\r\n\r\n              }\r\n            ]\r\n          }\r\n        ]\r\n      })\r\n      window.addEventListener('resize', function () {\r\n        myChart.resize()\r\n      })\r\n    }\r\n  }\r\n}\r\n\r\n</script>\r\n\r\n\r\n\r\n"]}]}