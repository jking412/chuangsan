rt = echarts.init(document.getElementById('boa6'))\n      // 绘制图表\n      myChart.setOption({\n        title: {\n          text: '学生对该课程偏好度',\n          left: 'center'\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter(e) {\n            return `${e.name}的学生人数为 : ${e.data.values}`//将他动态设置 name就是名字 values是我给他新添加的真实数据\n          }\n        },\n        legend: {\n          data: ['热爱这门课', '喜欢这门课', '能接受这门课', '疲于接受这门课', '厌倦这门课'],\n          left: 'center',\n          top: 'bottom',\n        },\n        series: [\n          {\n            name: 'prefer',\n            type: 'funnel',\n            left: '10%',\n            top: 60,\n            bottom: 60,\n            width: '80%',\n            min: 0,\n            max: 100,\n            minSize: '0%',\n            maxSize: '100%',\n            sort: 'ascending',\n            gap: 2,\n            label: {\n              show: true,\n              position: 'inside',\n              formatter(e) {\n                return `${e.data.values}`\n              },\n            },\n            labelLine: {\n              length: 10,\n              lineStyle: {\n                width: 1,\n                type: 'solid'\n              }\n            },\n            itemStyle: {\n              borderColor: '#fff',\n              borderWidth: 1\n            },\n            emphasis: {\n              label: {\n                fontSize: 20\n              }\n            },\n            data: [\n              { value: 20, name: '热爱这门课', values: 30 },\n              { value: 40, name: '喜欢这门课', values: 20 },\n              { value: 60, name: '能接受这门课', values: 0 },\n              { value: 80, name: '疲于接受这门课', values: 80 },\n              { value: 100, name: '厌倦这门课', values: 100 }\n            ]\n          }\n        ]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n"]}]}