\n        },\n        {\n          \"name\": \"液体运动的描述方法\",\n          \"value\": 906\n        },\n        {\n          \"name\": \"液流阻力和水头损失分类及计算公式\",\n          \"value\": 825\n        },\n        {\n          \"name\": \"量纲和谐原理\",\n          \"value\": 514\n        },\n        {\n          \"name\": \"水力学的发展简史\",\n          \"value\": 486\n        },\n        {\n          \"name\": \"液体的平衡微分方程\",\n          \"value\": 53\n        },\n        {\n          \"name\": \"液体流动的类型\",\n          \"value\": 163\n        },\n        {\n          \"name\": \"短管恒定岀流\",\n          \"value\": 86\n        },\n        {\n          \"name\": \"重力场中静压强分布规律\",\n          \"value\": 17\n        },\n        {\n          \"name\": \"描述液体运动的基本概念\",\n          \"value\": 6\n        },\n        {\n          \"name\": \"流动相似原理\",\n          \"value\": 1\n        },\n        {\n          \"name\": \"液体的力学模型\",\n          \"value\": 1437\n        },\n        {\n          \"name\": \"静水压强的量测及分布图\",\n          \"value\": 422\n        },\n        {\n          \"name\": \"液体的连续性方程\",\n          \"value\": 353\n        },\n        {\n          \"name\": \"作用在液体上的力\",\n          \"value\": 331\n        },\n        {\n          \"name\": \"作用在平面上的静水总压力\",\n          \"value\": 313\n        },\n        {\n          \"name\": \"理想液体运动的微分方程\",\n          \"value\": 307\n        },\n        {\n          \"name\": \"恒定总流动量方程\",\n          \"value\": 43\n        },\n        {\n          \"name\": \"简单长管水力计算\",\n          \"value\": 15\n        },\n\n        ],\n        image: \"data:image/png;base64,\"\n      }\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      // 基于准备好的dom，初始化echarts实例\n      let that = this\n      console.log(that.data);\n      var myChart = echarts.init(document.getElementById('ana5'));\n      var maskImage = new Image();\n      maskImage.src = that.data.image;\n      // 绘制图表\n      maskImage.onload = function () {\n        myChart.setOption(\n          {\n            series: [{\n              type: 'wordCloud',\n              layoutAnimation: true,\n              maskImage: maskImage,\n              sizeRange: [30, 100],\n              rotationRange: [0, 0],\n              rotationStep: 45,\n              gridSize: 8,\n              shape: 'pentagon',\n              width: '100%',\n              height: '100%',\n              textStyle: {\n                color: function () {\n                  return 'rgb(' + [\n                    Math.round(Math.random() * 160),\n                    Math.round(Math.random() * 160),\n                    Math.round(Math.random() * 160)\n                  ].join(',') + ')';\n                },\n                fontFamily: 'sans-serif',\n                fontWeight: 'normal',\n                emphasis: {\n                  shadowBlur: 10,\n                  shadowColor: '#333'\n                }\n              },\n              data: that.data.value,\n\n            }]\n          }\n        );\n        window.addEventListener('resize', function () {\n          myChart.resize()\n        });\n      }\n    }\n  }\n}\n</script>\n\n\n\n"]}]}