tom',\n          data: ['班级平均值', '个人成绩']\n        },\n        xAxis: {\n          name: '考试第次',\n          type: 'category',\n          boundaryGap: false,\n          data: ['1', '2', '3', '4', '5', '6', '7'],\n          nameLocation: \"middle\",\n          nameGap: 20\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          name: '班级平均值',\n          data: [61, 54, 70, 65, 67, 78, 71],\n          type: 'line',\n          smooth: true,\n          color: '#0d7ef6',\n\n        },\n        {\n          name: '个人成绩',\n          data: [71, 50, 85, 70, 76, 87, 94,],\n          type: 'line',\n          smooth: true,\n          areaStyle: {\n\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#7db6ef'\n            },\n\n            {\n              offset: 0.85,\n              color: 'rgba(126,171,233,0)'\n            }\n            ], false),\n\n\n          },\n\n        }]\n      })\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n\n\n\n"]}]}