"box1\"></chart7>\n          <div class=\"anibox\">\n            <lottie :options=\"defaultOptions\" @animCreated=\"handleAnimation\" class=\"pp1\" />\n          </div>\n\n        </div>\n        <div class=\"up-right\">\n\n          <dv-border-box-8 :reverse=\"true\" style=\"scale: 1.02\">\n            <span class='charttitle'><span class=\"title-10\">任务点完成情况</span></span>\n            <chart4></chart4>\n          </dv-border-box-8>\n        </div>\n      </div>\n      <div class=\"down-card\">\n        <div class=\"down-1\">\n          <dv-border-box-8 :reverse=\"true\" style=\"scale: 1.02\">\n            <span class='charttitle'><span class=\"title-10\">作业完成情况</span></span>\n            <chart1></chart1>\n          </dv-border-box-8>\n        </div>\n        <div class=\"down-2\">\n          <dv-border-box-8 :reverse=\"true\" style=\"scale: 1.02\">\n            <span class='charttitle'><span class=\"title-10\">成绩分析</span></span>\n            <chart6></chart6>\n          </dv-border-box-8>\n        </div>\n\n        <div class=\"down-3\">\n          <dv-border-box-8 :reverse=\"true\" style=\"scale: 1.02\">\n            <span class='charttitle'><span class=\"title-10\">课堂活动参与度</span></span>\n            <chart3></chart3>\n          </dv-border-box-8>\n        </div>\n        <div class=\"down-4\">\n          <dv-border-box-8 :reverse=\"true\" style=\"scale: 1.02\">\n            <span class='charttitle'><span class=\"title-10\">到课情况</span></span>\n\n          </dv-border-box-8>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport Navbar from '../title.vue'\nimport chart1 from './Maps/Job_completion.vue'\nimport chart2 from './Maps/Class_arrival.vue'\nimport chart3 from './Maps/Class_activities.vue'\nimport chart4 from './Maps/Task_point_completion.vue'\nimport chart5 from './Maps/test.vue'\nimport chart6 from \"./Maps/Score.vue\"\nimport chart7 from './Maps/Learning_preference.vue'\nimport * as lottieJson from \"../../../assets/media/loop.json\";\nexport default {\n  name: 'teacher-boardone',\n  data() {\n    return {\n      defaultOptions: {\n        animationData: lottieJson.default /*文件资源*/,\n      },\n      animationSpeed: 1 /*动画速度*/,\n      config: {\n        header: ['姓名', '挂科率', '学习进度', '学习态度', '学科总评'],\n        data: [\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n          ['小红', '98%', '16', '12', '66'],\n        ],\n        headerBGC: '#03044a',\n        oddRowBGC: '#00337f',\n        evenRowBGC: '#005fa9',\n        waitTime: 2000,\n        align: [\"center\", \"center\", \"center\", \"center\", \"center\"],\n      }\n    };\n  },\n  methods: {\n    handleAnimation: function (anim) {\n      this.anim = anim;\n    },\n    //当滑块控件值发生改变时，改变动画的速度\n    onSpeedChange: function () {\n      this.anim.setSpeed(this.animationSpeed);\n    },\n  },\n  components: {\n    Navbar,\n    chart1,\n    chart2,\n    chart3,\n    chart4,\n    chart5,\n    chart6,\n    chart7\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.teacher-card {\n  width: 100%;\n  height: 100%;\n  // background: linear-gradient(225deg, #2f334d, #383d5c);\n  background: #03044A;\n}\n\n.card-container {\n  width: 100%;\n  height: calc(100% - 60px);\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  padding: 20px;\n}\n\n.card-container .up-card {\n  width: 100%;\n  height: 61%;\n  display: flex;\n  justify-content: space-between;\n}\n\n.card-container .up-card .up-left {\n  height: 100%;\n  width: 30%;\n  // background-color: #313653;\n  // box-shadow: -25px 25px 45px #282c42, 25px -25px 45px #40466a;\n  // background-color: #0D1341;\n}\n\n.card-container .up-card .up-middle {\n  height: 100%;\n  width: 30%;\n  // background-color: #313653;\n}\n\n.card-container .up-card .up-right {\n  height: 100%;\n  width: 30%;\n  // background-color: #313653;\n  background-color: #0D1341;\n}\n\n.card-container .down-card {\n  width: 100%;\n  height: 35%;\n  display: flex;\n  justify-content: space-between;\n}\n\n.card-container .down-card .down-1 {\n  width: 24%;\n  height: 100%;\n  // background-color: #313653;\n  // box-shadow: -25px 25px 45px #282c42, 25px -25px 45px #40466a;\n  background-color: #0D1341;\n}\n\n.card-container .down-card .down-2 {\n  width: 24%;\n  height: 100%;\n  // background-color: #313653;\n  // box-shadow: -25px 25px 45px #282c42, 25px -25px 45px #40466a;\n  background-color: #0D1341;\n}\n\n.card-container .down-card .down-3 {\n  width: 24%;\n  height: 100%;\n  // background-color: #313653;\n  // box-shadow: -25px 25px 45px #282c42, 25px -25px 45px #40466a;\n  background-color: #0D1341;\n  border: 0px;\n}\n\n.card-container .down-card .down-4 {\n  width: 24%;\n  height: 100%;\n  // background-color: #313653;\n  // box-shadow: -25px 25px 45px #282c42, 25px -25px 45px #40466a;\n  background-color: #0D1341;\n}\n\n\n\n.pp1 {\n  height: 30vh;\n  width: 30vw;\n}\n\n.charttitle {\n  position: absolute;\n  display: inline-block;\n  color: #6EDDF1;\n  background: #14418E;\n  left: 50%;\n  font-size: 15px;\n  transform: translate(-50%, -50%);\n\n  .title-4 {\n    display: inline-block;\n    padding: 5px 14px;\n    background: radial-gradient(2.4rem 1rem ellipse, rgba(7, 9, 34, .8) 60%, rgb(21, 67, 145));\n  }\n\n  .title-6 {\n    display: inline-block;\n    padding: 5px 14px;\n    background: radial-gradient(3rem 0.9rem ellipse, rgba(7, 9, 34, .8) 60%, rgb(21, 67, 145));\n  }\n\n  .title-8 {\n    display: inline-block;\n    padding: 5px 14px;\n    background: radial-gradient(3.75rem 0.9rem ellipse, rgba(7, 9, 34, .8) 60%, rgb(21, 67, 145));\n  }\n\n  .title-10 {\n    display: inline-block;\n    padding: 5px 14px;\n    background: radial-gradient(4.75rem 0.9rem ellipse, rgba(7, 9, 34, .8) 60%, rgb(21, 67, 145));\n  }\n\n}\n\n.anibox {\n  height: 40vh;\n  width: 40vw;\n  position: absolute;\n  top: 18vh;\n  left: 30vw;\n  z-index: 5;\n}\n\n.box1 {\n  position: relative;\n  z-index: 99;\n}\n</style>\n"]}]}