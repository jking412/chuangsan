     { value: 35, name: '课程讨论' },\n        { value: 54, name: '计时器活动' },\n        { value: 36, name: '资源型活动' },\n        { value: 24, name: '在线课堂' },\n        { value: 20, name: '其他活动' }\n      ],\n    }\n  },\n  mounted() {\n    this.drawLine()\n  },\n  methods: {\n    drawLine() {\n      let that = this\n      // 基于准备好的dom，初始化echarts实例\n      var myChart = echarts.init(document.getElementById('map5'))\n      // 绘制图表\n      myChart.setOption(\n        {\n          title: {\n            text: '课堂活动参与度',\n\n            left: 'center'\n          },\n          tooltip: {\n            trigger: 'item',\n            axisPointer: { //去掉移动的指示线\n              type: 'none'\n            },\n            formatter: '{b}:<br/>{c}人次，占总人次的{d}%'\n            // return arg.name + `<br>` + arg.value[0] + '/' + arg.value[1] + `<br>` + (arg.value[0] / arg.value[1] * 100).toFixed(2) + '%'\n\n          },\n          legend: {\n            x: \"center\",\n            y: \"bottom\",\n          },\n\n          series: [\n            {\n              name: 'Access From',\n              type: 'pie',\n              radius: '50%',\n              data: that.data,\n              emphasis: {\n                itemStyle: {\n                  shadowBlur: 10,\n                  shadowOffsetX: 0,\n                  shadowColor: 'rgba(0, 0, 0, 0.5)'\n                }\n              },\n              selectedMode: 'multiple',\n              selectedOffset: 15\n            }\n          ]\n        }\n      )\n      window.addEventListener('resize', function () {\n        myChart.resize()\n      })\n    }\n  }\n}\n\n</script>\n"]}]}