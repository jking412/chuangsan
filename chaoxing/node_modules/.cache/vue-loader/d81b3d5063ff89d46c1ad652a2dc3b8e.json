CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/student/dashboard","sourcesContent":["<template>\n  <div class=\"dashboard-container\" style=\"font-family: PR;\">\n    <div class=\"up-card\">\n      <!-- <div class=\"tasks-card\" @mouseover=\"mouseover\" @mouseleave=\"mouseleave\">\n        <div class=\"select\">\n          <el-select v-model=\"clazzIndex\" placeholder=\"请选择分析学科\">\n            <el-option v-for=\"(item, index) in clazzes\" :key=\"item.id\" :label=\"item.name\" :value=\"index\"\n              @click.native=\"change(index)\">\n            </el-option>\n          </el-select>\n        </div>\n        <div style=\"color: #979797; font-weight: 700; display: flex;\">进度<el-progress :percentage=\"20\"\n          :stroke-width=\"12\"></el-progress></div>\n        <div class=\"task-list\">\n          <el-table :data=\"tasks\" stripe style=\"width: 100%\" height=\"280px\" ref=\"table\">\n            <el-table-column prop=\"name\" label=\"任务点名称\" width=\"140\">\n            </el-table-column>\n            <el-table-column prop=\"status\" label=\"状态\">\n            </el-table-column>\n          </el-table>\n        </div>\n      </div> -->\n      <div class=\"basic-card\">\n        <div class=\"four-card\">\n          <div class=\"basic-word\">\n            <h4 style=\"color: #979797;\">课堂总签到数: 20</h4>\n            <h3 style=\"font-weight: 600;\">有效签到数: </h3>\n            <h1 style=\"color: #4791fc; font-size: 38px\"><svg-icon icon-class=\"sign\"\n                style=\"color: #3481F5; font-size: 26px\" /> + 12</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart4></chart4>\n          </div>\n        </div>\n        <div class=\"four-card\">\n          <div class=\"basic-word\">\n            <h4 style=\"color: #979797;\">课堂活动总数: 28</h4>\n            <h3 style=\"font-weight: 600\">课堂活动参与数: </h3>\n            <h1 style=\"color: #4791fc; font-size: 38px\"><svg-icon icon-class=\"join\"\n                style=\"color: #1296db; font-size: 30px\" /> + 18</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart5></chart5>\n          </div>\n        </div>\n        <div class=\"four-card\">\n          <div class=\"basic-word\">\n            <h4 style=\"color: #979797;\">作业总发布数: 24</h4>\n            <h3 style=\"font-weight: 600\">作业完成数: </h3>\n            <h1 style=\"color: #4791fc; font-size: 38px\"><svg-icon icon-class=\"homework\"\n                style=\"color: #409EFF; font-size: 30px\" /> + 19</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart6></chart6>\n          </div>\n        </div>\n        <div class=\"four-card\">\n          <div class=\"basic-word\">\n            <h4 style=\"color: #979797;\">挂科预警分析</h4>\n            <h3 style=\"font-weight: 600\">当前挂科风险: </h3>\n            <h1 style=\"color: red; font-size: 38px\"><svg-icon icon-class=\"warning\"\n                style=\"color: #E65256; font-size: 30px\" /> + 12</h1>\n          </div>\n          <div class=\"basic-chart\">\n            <chart7></chart7>\n          </div>\n        </div>\n      </div>\n      <div class=\"tasks-card\" style=\"width: 40%\" @mouseover=\"mouseover\" @mouseleave=\"mouseleave\">\n        <div style=\"color: #979797; font-weight: 700; display: flex; align-items: center\">\n          <div style=\"width: 40%;margin-right:8px\">\n            <el-select v-model=\"select\" placeholder=\"select\">\n              <el-option v-for=\"(item, index) in selects\" :key=\"item.value\" :label=\"item.label\" :value=\"item.value\"\n                :index=\"index\" id=\"select\">\n              </el-option>\n            </el-select>\n          </div>\n          <div style=\"width: 60%; display:flex;align-items: center\">\n            进度<el-progress :percentage=\"this.selects[index].rate\" :stroke-width=\"14\"></el-progress>\n          </div>\n        </div>\n        <div class=\"task-list\">\n          <el-table :data=\"choose()\" style=\"width: 100%;\" height=\"284px\" ref=\"table\">\n            <el-table-column prop=\"name\" label=\"名称\" min-width=\"40%\">\n            </el-table-column>\n            <el-table-column prop=\"status\" label=\"状态\" min-width=\"40%\">\n            </el-table-column>\n            <el-table-column prop=\"score\" label=\"得分\" min-width=\"20%\">\n            </el-table-column>\n          </el-table>\n        </div>\n      </div>\n    </div>\n    <div class=\"downcard1\">\n      <div class=\"downcard1Left\">\n        <chart2></chart2>\n        <el-popover placement=\"top-start\" title=\"你当前的互动度为170\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"order\" slot=\"reference\" style=\"font-size: 35px;\" class=\"icon1\">\n          </svg-icon>\n        </el-popover>\n        <el-popover placement=\"top-start\" title=\"你当前的主要互动行为是：问卷、课程讨论\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"behavior\" slot=\"reference\" style=\"font-size: 35px;\" class=\"icon2\">\n          </svg-icon>\n        </el-popover>\n      </div>\n      <div class=\"downcard1Right\">\n        <chart9></chart9>\n      </div>\n    </div>\n    <div class=\"downcard2\">\n      <div class=\"downcard2Left\">\n        <chart10></chart10>\n      </div>\n      <div class=\"downcard2Right\">\n        <chart11 class=\"tr\"></chart11>\n        <el-popover placement=\"top-start\" title=\"你当前的偏好学科为：高数、线代\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"prefer\" slot=\"reference\" style=\"font-size: 38px;\" class=\"icon3\">\n          </svg-icon>\n        </el-popover>\n        <el-popover placement=\"top-start\" title=\"你当前的学科评价等级为：A\" width=\"200\" trigger=\"hover\" :close-delay=\"10\">\n          <svg-icon icon-class=\"score\" slot=\"reference\" style=\"font-size: 38px;\" class=\"icon4\">\n          </svg-icon>\n        </el-popover>\n      </div>\n    </div>\n    <div class=\"downcard3\">\n      <el-dialog :title=\"this.taskpointName + '个人学情'\" :visible.sync=\"centerDialogVisible\" width=\"30%\" center\n        style=\" overflow: hidden;\">\n        <span style=\"font-size: 20px;display: flex;flex-wrap: wrap;justify-content: space-between;align-items: center;\">\n          <div style=\"width: 50%;\">\n            学习效果得分：<el-progress :percentage='taskpointContain[flag].value1' :stroke-width=\"12\"></el-progress><br>\n            学习总评得分：<el-progress :percentage='taskpointContain[flag].value2' :stroke-width=\"12\"\n              color=\"#67c23a\"></el-progress><br>\n            当前学科评价等级为：<span style=\"color: #dc143c;\">{{ taskpointContain[flag].value3 }}</span><br>\n          </div>\n\n          0. <div style=\"width: 45%;height: 200px;\">\n            <chart12 :value=\"taskpointContain[flag].value4\" style=\"width: 100%;height: 100%;\"></chart12>\n          </div>\n          <br>您的综合评价等级超过了班级中{{\n            taskpointContain[flag].value4 * 100 + '%' }}的人\n\n        </span>\n        <span slot=\"footer\" class=\"dialog-footer\">\n          <el-button @click=\"centerDialogVisible = false\">取 消</el-button>\n          <el-button type=\"primary\" @click=\"centerDialogVisible = false\">确 定</el-button>\n        </span>\n      </el-dialog>\n      <chart1 @callback=\"callback\"></chart1>\n    </div>\n  </div>\n</template>\n<script>\nimport store from '../../../store'\nimport { arrApi, jobApi, actRateApi, examApi, workApi, bbsApi } from './api'\n\nimport chart1 from './Maps/Analysis_of_student_achievement.vue'\nimport chart2 from './Maps/Class_activities.vue'\nimport chart4 from './Maps/Circle-1.vue'\nimport chart5 from './Maps/Circle-2.vue'\nimport chart6 from './Maps/Circle-3.vue'\nimport chart7 from './Maps/Circle-4.vue'\nimport chart9 from './Maps/Radar_chart'\nimport chart10 from './Maps/Discussion_flow_chart.vue'\nimport chart11 from './Maps/Subject_preference.vue'\nimport chart12 from './Maps/Circle-5.vue'\nexport default {\n  name: 'Dashboard',\n  data() {\n    return {\n      centerDialogVisible: false,\n      taskpointName: '',\n      flag: 0,\n      index: 1,\n      taskpointContain: [{\n        value1: 65,\n        value2: 85,\n        value3: \"B+\",\n        value4: 0.8\n      },\n      {\n        value1: 76,\n        value2: 88,\n        value3: \"A\",\n        value4: 0.9\n      }\n      ],\n      person: {\n        Username: '李四',\n        UserId: 19201080\n      },\n      tasks: [\n        { name: '任务点1', status: '已完成', score: '12' },\n        { name: '任务点2', status: '已完成', score: '12' },\n        { name: '任务点3', status: '已完成', score: '12' },\n        { name: '任务点4', status: '未完成', score: '12' },\n        { name: '任务点5', status: '未完成', score: '12' },\n        { name: '任务点6', status: '未完成', score: '12' },\n        { name: '任务点7', status: '未完成', score: '12' },\n      ],\n      homework: [\n        { name: '作业1', status: '已完成', score: '12' },\n        { name: '作业2', status: '已完成', score: '12' },\n        { name: '作业3', status: '已完成', score: '12' },\n        { name: '作业4', status: '未完成', score: '12' },\n        { name: '作业5', status: '未完成', score: '12' },\n        { name: '作业6', status: '未完成', score: '12' },\n        { name: '作业7', status: '未完成', score: '12' },\n        { name: '作业8', status: '未完成', score: '12' },\n        { name: '作业9', status: '未完成', score: '12' },\n        { name: '作业10', status: '未完成', score: '12' },\n        { name: '作业11', status: '未完成', score: '12' },\n        { name: '作业12', status: '未完成', score: '12' },\n        { name: '作业13', status: '未完成', score: '12' },\n        { name: '作业14', status: '未完成', score: '12' },\n        { name: '作业15', status: '未完成', score: '12' },\n        { name: '作业16', status: '未完成', score: '12' },\n      ],\n      exam: [\n        { name: '考试1', status: '已完成', score: '12' },\n        { name: '考试2', status: '已完成', score: '12' },\n        { name: '考试3', status: '已完成', score: '12' },\n        { name: '考试4', status: '已完成', score: '12' },\n        { name: '考试5', status: '已完成', score: '12' },\n        { name: '考试6', status: '未完成', score: '12' },\n        { name: '考试7', status: '未完成', score: '12' },\n        { name: '考试8', status: '未完成', score: '12' },\n        { name: '考试9', status: '未完成', score: '12' },\n      ],\n      select: 'homework',\n      selects: [{\n        value: 'homework',\n        label: '作业',\n        rate: 80\n      }, {\n        value: 'exam',\n        label: '考试',\n        rate: 90\n      }, {\n        value: 'tasks',\n        label: '任务点',\n        rate: 70\n      }],\n      timer: 0,\n      Info: store.getters.Info,\n      clazzIndex: 0,\n      clazzes: store.getters.Info.clazzes,\n      job: ''\n    }\n  },\n  methods: {\n    callback(data) {\n      this.centerDialogVisible = data[0];\n      this.taskpointName = data[1];\n      if (this.taskpointName == \"第四周\")\n        this.flag = 1\n      else\n        this.flag = 0\n    },\n\n    getright_table() {\n      let isScroll = true\n      var this_ = this\n      this.$nextTick(() => {\n        let t = document.getElementsByClassName(\"el-table__body\")[0];\n        this.timer = setInterval(() => {\n          if (this.select === 'homework') {\n            if (isScroll) {\n              var data = this_.homework[0];\n              setTimeout(() => {\n                this_.homework.push(data);\n                t.style.transition = \"all .5s\";\n                t.style.marginTop = \"-47.67px\";\n              }, 500);\n              setTimeout(() => {\n                this_.homework.splice(0, 1);\n                t.style.transition = \"all 0s ease 0s\";\n                t.style.marginTop = \"0\";\n              }, 1000);\n            }\n          } else {\n            if (isScroll) {\n              var data = this_.exam[0];\n              setTimeout(() => {\n                this_.exam.push(data);\n                t.style.transition = \"all 1s\";\n                t.style.marginTop = \"-58px\";\n              }, 500);\n              setTimeout(() => {\n                this_.exam.splice(0, 1);\n                t.style.transition = \"all 0s ease 0s\";\n                t.style.marginTop = \"0\";\n              }, 1000);\n            }\n          }\n        }, 2500);\n      });\n    },\n    mouseover() {\n      clearInterval(this.timer)\n    },\n    mouseleave() {\n      this.getright_table()\n    },\n    choose() {\n      if (this.select === 'homework') {\n        return this.homework\n      } else if (this.select === 'exam') {\n        return this.exam\n      } else {\n        return this.tasks\n      }\n    },\n    change(index) {\n      this.getJob(index)\n      this.getArr(index)\n      this.getActRate(index)\n      this.getWork(index)\n      this.getExam(index)\n    },\n    getJob(index) {\n      jobApi(this.clazzes[index].course.courseid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getArr(index) {\n      arrApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getActRate(index) {\n      actRateApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getExam(index) {\n      examApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getWork(index) {\n      workApi(this.clazzes[index].clazzid).then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n    getBBS() {\n      bbsApi().then(res => {\n        console.log(res);\n      }).catch(err => {\n        console.log(err);\n      })\n    },\n\n  },\n  mounted() {\n    this.getright_table();\n  },\n  updated() {\n    this.index = $(\"select\").attr(\"index\")\n  },\n  beforeDestroy() {\n    clearInterval(this.timer)\n  },\n  components: {\n    chart1,\n    chart2,\n    chart4,\n    chart5,\n    chart6,\n    chart7,\n    chart9,\n    chart10,\n    chart11,\n    chart12\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.dashboard {\n  &-container {\n    margin: 30px;\n  }\n}\n\n.el-table {\n  font-family: PR;\n  /* 继承全局字体样式 */\n}\n\n.dashboard-container .up-card {\n  display: flex;\n  width: 100%;\n  justify-content: space-between;\n}\n\n@keyframes jump {\n  0% {\n    transform: translate(0px, 0px);\n  }\n\n  50% {\n    transform: translate(0px, -10px);\n  }\n\n  100% {\n    transform: translate(0px, 0px);\n  }\n}\n\n.dashboard-container .up-card .select {\n  height: 6vh;\n  width: 100%;\n}\n\n.dashboard-container .up-card .basic-card {\n  display: flex;\n  width: 58%;\n  height: 42vh;\n  flex-wrap: wrap;\n  justify-content: space-between;\n  align-content: space-between;\n}\n\n.dashboard-container .up-card .basic-card .four-card {\n  width: 48%;\n  height: 20vh;\n  border-radius: 20px;\n  background-color: #fff;\n  overflow: hidden;\n  display: flex;\n  transition-duration: 0.3s;\n}\n\n.dashboard-container .up-card .basic-card .four-card:hover {\n  cursor: pointer;\n  box-shadow: 0 10px 10px -10px rgba(0, 0, 0, 0.5);\n  transform: scale(1.1);\n}\n\n.dashboard-container .up-card .basic-card .four-card .basic-word {\n  width: 50%;\n  height: 100%;\n  padding: 15px 0px 0px 35px;\n}\n\n.dashboard-container .up-card .basic-card .four-card .basic-chart {\n  width: 50%;\n  height: 100%;\n}\n\n.dashboard-container .up-card .tasks-card {\n  width: 38%;\n  padding: 20px;\n  height: 42vh;\n  border-radius: 20px;\n  margin: 0px 0px 20px 0px;\n  background-color: #fff;\n  transition-duration: 0.3s;\n  display: flex;\n  flex-direction: column;\n}\n\n.dashboard-container .up-card .tasks-card:hover {\n  cursor: pointer;\n  box-shadow: 0 10px 10px -10px rgba(0, 0, 0, 0.5);\n  transform: scale(1.1);\n}\n\n.dashboard-container .up-card .tasks-card .el-progress {\n  margin-left: 1em;\n  width: 80%;\n}\n\n.dashboard-container .up-card .tasks-card .task-list {\n  margin-top: 10px;\n  width: 100%;\n  height: 30vh;\n  overflow: hidden;\n}\n\n.downcard1 {\n  display: flex;\n  width: 100%;\n  height: 50vh;\n  justify-content: space-between;\n  margin-top: 15px;\n}\n\n.downcard1 .downcard1Left {\n  position: relative;\n  display: flex;\n  width: 47.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard1 .downcard1Right {\n  display: flex;\n  width: 50.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 {\n  display: flex;\n  width: 100%;\n  height: 50vh;\n  justify-content: space-between;\n  margin-top: 30px;\n}\n\n.downcard2 .downcard2Left {\n  display: flex;\n  width: 47.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 .downcard2Right {\n  display: flex;\n  width: 50.5%;\n  height: 50vh;\n  flex-direction: row;\n\n  background: #fff;\n  border-radius: 20px;\n}\n\n.downcard2 .downcard2Right .tr {\n  transform: translateX(5%);\n}\n\n//#region\n// .dashboard-container .down-card .contain {\n//   width: 750px;\n//   height: 450px;\n//   background-color: #fff;\n// }\n\n// .dashboard-container .down-card .contain1 {\n//   width: 800px;\n//   height: 480px;\n//   background-color: #fff;\n// }\n\n.downcard1 .icon1 {\n  position: absolute;\n  top: 4vw;\n  left: 6vw;\n  color: #979797;\n\n  &:hover {\n    color: #409EFF;\n    cursor: pointer;\n  }\n}\n\n.downcard1 .icon2 {\n  position: absolute;\n  color: #979797;\n  top: 4vw;\n  left: 3vw;\n\n  &:hover {\n    color: #f4ea2a;\n    cursor: pointer;\n  }\n}\n\n.downcard2 .icon3 {\n  position: absolute;\n  top: 114vh;\n  right: 38vw;\n  color: #979797;\n\n  &:hover {\n    color: #409EFF;\n    cursor: pointer;\n  }\n}\n\n.downcard2 .icon4 {\n  position: absolute;\n  top: 114vh;\n  right: 35vw;\n  color: #979797;\n\n  &:hover {\n    color: #409EFF;\n    cursor: pointer;\n  }\n}\n\n.downcard3 {\n  display: flex;\n  width: 100%;\n  height: 55vh;\n  justify-content: space-between;\n  margin-top: 30px;\n  background-color: #fff;\n  border-radius: 20px;\n}\n\n// .dashboard-container .down-card .icon3 {\n//   position: absolute;\n//   color: #979797;\n//   top: 6vh;\n//   left: 5vw;\n\n//   &:hover {\n//     color: #409EFF;\n//     cursor: pointer;\n//   }\n// }\n\n// .dashboard-container .down-card {\n//   display: flex;\n//   width: 100%;\n//   flex-direction: column;\n//   margin-top: 40px;\n// }\n//#endregion\n</style>\n"]}]}